@model School.Web.Models.Fees.ChequesViewModel
@{ ViewData["Title"] = "Cheques"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-hourglass-split text-warning fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Pending Clearance</div>
                    <div class="fw-bold fs-4">₹@Model.TotalPending.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-success bg-opacity-10">
                    <i class="bi bi-check2-circle text-success fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Cleared</div>
                    <div class="fw-bold fs-4">₹@Model.TotalCleared.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-check2-circle me-2 text-primary"></i>Cheques</h6>
        <a asp-action="Index" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle me-1"></i>Record New Cheque</a>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-check2-circle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No cheques recorded yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Cheque No.</th>
                            <th>Date</th>
                            <th>GR No.</th>
                            <th>Student</th>
                            <th class="text-end">Amount</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ChequeNo</td>
                                <td>@item.ChequeDate.ToString("dd MMM yyyy")</td>
                                <td>@item.GRNumber</td>
                                <td>@item.StudentName</td>
                                <td class="text-end">₹@item.Amount.ToString("N2")</td>
                                <td>
                                    @if (item.IsCleared)
                                    {
                                        <span class="badge bg-success-subtle text-success">Cleared</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning">Pending</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="UpdateChequeStatusFromList" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chequeId" value="@item.Id" />
                                        <input type="hidden" name="isCleared" value="@((!item.IsCleared).ToString().ToLower())" />
                                        <button type="submit" class="btn btn-sm @(item.IsCleared ? "btn-outline-warning" : "btn-outline-success")">
                                            @(item.IsCleared ? "Mark Pending" : "Mark Cleared")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
