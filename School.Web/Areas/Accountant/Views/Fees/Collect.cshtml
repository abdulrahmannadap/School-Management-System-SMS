@model School.Web.Models.Fees.CollectFeeViewModel
@{ ViewData["Title"] = "Collect Fee"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>@Model.Student.FullName</h6>
            <div class="text-muted small">GR No. @Model.Student.GRNumber &middot; @Model.Student.Gender</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Search</a>
    </div>
</div>

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-receipt",       "bg-primary", "Total Fees",     $"₹{Model.Pending.TotalFees:N2}"),
        ("bi-cash-stack",    "bg-success", "Paid",           $"₹{Model.Pending.PaidAmount:N2}"),
        ("bi-clock-history", "bg-danger",  "Pending",        $"₹{Model.Pending.PendingAmount:N2}"),
    })
    {
        <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Fee Ledger</h6>
            </div>
            <div class="card-body">
                @if (!Model.Ledger.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No ledger entries yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th class="text-end">Debit</th>
                                    <th class="text-end">Credit</th>
                                    <th>Reference</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.Ledger)
                                {
                                    <tr>
                                        <td>@entry.Date.ToString("dd MMM yyyy")</td>
                                        <td>@entry.Type</td>
                                        <td class="text-end">@(entry.Debit > 0 ? $"₹{entry.Debit:N2}" : "—")</td>
                                        <td class="text-end">@(entry.Credit > 0 ? $"₹{entry.Credit:N2}" : "—")</td>
                                        <td>@entry.ReferenceNo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Payment History</h6>
            </div>
            <div class="card-body">
                @if (!Model.Payments.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No payments recorded yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Mode</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Payments)
                                {
                                    <tr>
                                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                        <td>@p.PaymentMode</td>
                                        <td class="text-end">₹@p.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-cash-coin me-2 text-primary"></i>Receive Payment</h6>
            </div>
            <div class="card-body">
                <form asp-action="ReceivePayment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Form.StudentId" />
                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Date</label>
                        <input asp-for="Form.PaymentDate" type="date" class="form-control" />
                        <span asp-validation-for="Form.PaymentDate" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Mode</label>
                        <select asp-for="Form.PaymentMode" class="form-select">
                            <option value="">Select mode</option>
                            <option value="Cash">Cash</option>
                            <option value="Cheque">Cheque</option>
                            <option value="Online">Online</option>
                            <option value="Card">Card</option>
                        </select>
                        <span asp-validation-for="Form.PaymentMode" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reference No.</label>
                        <input asp-for="Form.ReferenceNo" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check2-circle me-1"></i>Receive Payment</button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-percent me-2 text-primary"></i>Discount</h6>
            </div>
            <div class="card-body">
                @if (Model.Discounts.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Reason</th><th class="text-end">Amount</th></tr></thead>
                            <tbody>
                                @foreach (var d in Model.Discounts)
                                {
                                    <tr><td>@d.Reason</td><td class="text-end">₹@d.Amount.ToString("N2")</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <form asp-action="ApplyDiscount" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="DiscountForm.StudentId" />
                    <div class="mb-2">
                        <input asp-for="DiscountForm.Amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="Amount" />
                        <span asp-validation-for="DiscountForm.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <input asp-for="DiscountForm.Reason" class="form-control form-control-sm" placeholder="Reason" />
                        <span asp-validation-for="DiscountForm.Reason" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100">Apply Discount</button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-arrow-counterclockwise me-2 text-primary"></i>Refund</h6>
            </div>
            <div class="card-body">
                @if (Model.Refunds.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Reason</th><th class="text-end">Amount</th></tr></thead>
                            <tbody>
                                @foreach (var r in Model.Refunds)
                                {
                                    <tr><td>@r.Reason</td><td class="text-end">₹@r.Amount.ToString("N2")</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <form asp-action="ProcessRefund" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RefundForm.StudentId" />
                    <div class="mb-2">
                        <input asp-for="RefundForm.Amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="Amount" />
                        <span asp-validation-for="RefundForm.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <input asp-for="RefundForm.Reason" class="form-control form-control-sm" placeholder="Reason" />
                        <span asp-validation-for="RefundForm.Reason" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">Process Refund</button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-safe me-2 text-primary"></i>Deposit</h6>
            </div>
            <div class="card-body">
                @if (Model.DepositTransactions.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Date</th><th>Type</th><th class="text-end">Amount</th></tr></thead>
                            <tbody>
                                @foreach (var d in Model.DepositTransactions)
                                {
                                    <tr>
                                        <td>@d.Date.ToString("dd MMM yyyy")</td>
                                        <td>@d.Type</td>
                                        <td class="text-end">₹@d.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (!Model.DepositMasters.Any())
                {
                    <p class="text-muted small mb-0">No deposit types set up yet. Ask SchoolAdmin to add one under Fees &gt; Deposit Master.</p>
                }
                else
                {
                    <form asp-action="RecordDeposit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="DepositForm.StudentId" />
                        <div class="mb-2">
                            <select asp-for="DepositForm.DepositMasterId" class="form-select form-select-sm">
                                <option value="">Select deposit type</option>
                                @foreach (var dm in Model.DepositMasters)
                                {
                                    <option value="@dm.Id">@dm.DepositName</option>
                                }
                            </select>
                            <span asp-validation-for="DepositForm.DepositMasterId" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <input asp-for="DepositForm.Amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="Amount" />
                            <span asp-validation-for="DepositForm.Amount" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <input asp-for="DepositForm.Date" type="date" class="form-control form-control-sm" />
                            <span asp-validation-for="DepositForm.Date" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <select asp-for="DepositForm.Type" class="form-select form-select-sm">
                                <option value="Paid">Paid</option>
                                <option value="Refunded">Refunded</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Record Deposit</button>
                    </form>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-check2-circle me-2 text-primary"></i>Cheques</h6>
            </div>
            <div class="card-body">
                @if (Model.Cheques.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Cheque No.</th><th>Date</th><th class="text-end">Amount</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var c in Model.Cheques)
                                {
                                    <tr>
                                        <td>@c.ChequeNo</td>
                                        <td>@c.ChequeDate.ToString("dd MMM yyyy")</td>
                                        <td class="text-end">₹@c.Amount.ToString("N2")</td>
                                        <td>
                                            <form asp-action="UpdateChequeStatus" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="chequeId" value="@c.Id" />
                                                <input type="hidden" name="studentId" value="@Model.Student.Id" />
                                                <input type="hidden" name="isCleared" value="@((!c.IsCleared).ToString())" />
                                                @if (c.IsCleared)
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-success">Cleared</button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">Pending</button>
                                                }
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <form asp-action="AddCheque" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ChequeForm.StudentId" />
                    <div class="mb-2">
                        <input asp-for="ChequeForm.ChequeNo" class="form-control form-control-sm" placeholder="Cheque No." />
                        <span asp-validation-for="ChequeForm.ChequeNo" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <input asp-for="ChequeForm.ChequeDate" type="date" class="form-control form-control-sm" />
                        <span asp-validation-for="ChequeForm.ChequeDate" class="text-danger small"></span>
                    </div>
                    <div class="mb-2">
                        <input asp-for="ChequeForm.Amount" type="number" step="0.01" class="form-control form-control-sm" placeholder="Amount" />
                        <span asp-validation-for="ChequeForm.Amount" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Add Cheque</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
