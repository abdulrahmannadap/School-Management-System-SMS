@model School.Web.Models.Fees.LedgerViewModel
@{ ViewData["Title"] = "Fee Ledger"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">From</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">To</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-danger bg-opacity-10">
                    <i class="bi bi-arrow-down-circle text-danger fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Debit</div>
                    <div class="fw-bold fs-4">₹@Model.TotalDebit.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-success bg-opacity-10">
                    <i class="bi bi-arrow-up-circle text-success fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Credit</div>
                    <div class="fw-bold fs-4">₹@Model.TotalCredit.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Fee Ledger</h6>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <p class="text-muted text-center py-3 mb-0">No ledger entries in this date range</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>GR No.</th>
                            <th>Student</th>
                            <th>Type</th>
                            <th>Reference</th>
                            <th class="text-end">Debit</th>
                            <th class="text-end">Credit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Date.ToString("dd MMM yyyy")</td>
                                <td>@item.GRNumber</td>
                                <td>@item.StudentName</td>
                                <td><span class="badge bg-secondary-subtle text-secondary">@item.Type</span></td>
                                <td class="text-muted small">@item.ReferenceNo</td>
                                <td class="text-end">@(item.Debit > 0 ? $"₹{item.Debit:N2}" : "—")</td>
                                <td class="text-end">@(item.Credit > 0 ? $"₹{item.Credit:N2}" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
