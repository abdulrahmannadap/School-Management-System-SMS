@model School.Web.Models.Fees.PendingFeesViewModel
@{ ViewData["Title"] = "Pending Fees"; }

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-danger bg-opacity-10">
                    <i class="bi bi-clock-history text-danger fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Pending</div>
                    <div class="fw-bold fs-4">₹@Model.TotalPending.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-people text-warning fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Students with Dues</div>
                    <div class="fw-bold fs-4">@Model.Items.Count</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Pending Fees</h6>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-check2-circle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No pending fees — every student is fully paid up.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>GR No.</th>
                            <th>Student</th>
                            <th class="text-end">Total Fees</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Pending</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.GRNumber</td>
                                <td>@item.StudentName</td>
                                <td class="text-end">₹@item.TotalFees.ToString("N2")</td>
                                <td class="text-end">₹@item.PaidAmount.ToString("N2")</td>
                                <td class="text-end fw-semibold text-danger">₹@item.PendingAmount.ToString("N2")</td>
                                <td class="text-end">
                                    <a asp-action="Collect" asp-route-studentId="@item.StudentId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-cash-coin me-1"></i>Collect
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
