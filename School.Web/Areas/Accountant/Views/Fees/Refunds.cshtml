@model School.Web.Models.Fees.RefundsViewModel
@{ ViewData["Title"] = "Refunds"; }

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-arrow-counterclockwise text-warning fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Refunded</div>
                    <div class="fw-bold fs-4">₹@Model.TotalAmount.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-arrow-counterclockwise me-2 text-primary"></i>Refunds</h6>
        <a asp-action="Index" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle me-1"></i>Process New Refund</a>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-arrow-counterclockwise" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No refunds processed yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>GR No.</th>
                            <th>Student</th>
                            <th>Reason</th>
                            <th class="text-end">Amount</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.GRNumber</td>
                                <td>@item.StudentName</td>
                                <td>@item.Reason</td>
                                <td class="text-end">₹@item.Amount.ToString("N2")</td>
                                <td class="text-end">
                                    <a asp-action="Collect" asp-route-studentId="@item.StudentId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
