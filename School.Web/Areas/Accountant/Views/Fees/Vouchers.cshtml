@model School.Web.Models.Fees.VoucherIndexViewModel
@{ ViewData["Title"] = "Vouchers"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-arrow-down-circle", "bg-success", "Total Income",  $"₹{Model.TotalIncome:N2}"),
        ("bi-arrow-up-circle",   "bg-danger",  "Total Expense", $"₹{Model.TotalExpense:N2}"),
    })
    {
        <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-sm-4">
                        <label class="form-label small">From</label>
                        <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small">To</label>
                        <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4">
                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Vouchers</h6>
            </div>
            <div class="card-body">
                @if (!Model.Items.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No vouchers in this date range</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in Model.Items)
                                {
                                    <tr>
                                        <td>@v.Date.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (v.Type == "Receipt")
                                            {
                                                <span class="badge bg-success-subtle text-success">Receipt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger">Payment</span>
                                            }
                                        </td>
                                        <td>@v.Description</td>
                                        <td class="text-end">₹@v.Amount.ToString("N2")</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    data-id="@v.Id" data-date="@v.Date.ToString("yyyy-MM-dd")"
                                                    data-type="@v.Type" data-amount="@v.Amount" data-description="@v.Description"
                                                    onclick="loadVoucherForEdit(this.dataset)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form asp-action="DeleteVoucher" method="post" class="d-inline" onsubmit="return confirm('Delete this voucher?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@v.Id" />
                                                <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                                                <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i><span id="voucherFormTitle">New Voucher</span></h6>
                <button type="button" class="btn btn-sm btn-link" id="cancelEditBtn" style="display:none" onclick="resetVoucherForm()">Cancel edit</button>
            </div>
            <div class="card-body">
                <form asp-action="SaveVoucher" method="post" id="voucherForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                    <input asp-for="Form.Id" type="hidden" id="Form_Id" />
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select asp-for="Form.Type" class="form-select" id="Form_Type">
                            <option value="Receipt">Receipt (Income)</option>
                            <option value="Payment">Payment (Expense)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input asp-for="Form.Date" type="date" class="form-control" id="Form_Date" />
                        <span asp-validation-for="Form.Date" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" id="Form_Amount" />
                        <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input asp-for="Form.Description" class="form-control" id="Form_Description" />
                        <span asp-validation-for="Form.Description" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100" id="voucherSubmitBtn"><i class="bi bi-check2-circle me-1"></i>Save Voucher</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function loadVoucherForEdit(data) {
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_Type').value = data.type;
            document.getElementById('Form_Date').value = data.date;
            document.getElementById('Form_Amount').value = data.amount;
            document.getElementById('Form_Description').value = data.description;
            document.getElementById('voucherFormTitle').innerText = 'Edit Voucher';
            document.getElementById('voucherSubmitBtn').innerHTML = '<i class="bi bi-check2-circle me-1"></i>Update Voucher';
            document.getElementById('cancelEditBtn').style.display = '';
            document.getElementById('voucherForm').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function resetVoucherForm() {
            document.getElementById('voucherForm').reset();
            document.getElementById('Form_Id').value = 0;
            document.getElementById('voucherFormTitle').innerText = 'New Voucher';
            document.getElementById('voucherSubmitBtn').innerHTML = '<i class="bi bi-check2-circle me-1"></i>Save Voucher';
            document.getElementById('cancelEditBtn').style.display = 'none';
        }

        @if (Model.Form.Id != 0)
        {
            <text>loadVoucherForEdit({ id: @Model.Form.Id, date: '@Model.Form.Date.ToString("yyyy-MM-dd")', type: '@Model.Form.Type', amount: @Model.Form.Amount, description: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Form.Description)) });</text>
        }
    </script>
}
