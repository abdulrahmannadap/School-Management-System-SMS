@model School.Web.Models.Fees.VoucherIndexViewModel
@{ ViewData["Title"] = "Vouchers"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-arrow-down-circle", "bg-success", "Total Income",  $"₹{Model.TotalIncome:N2}"),
        ("bi-arrow-up-circle",   "bg-danger",  "Total Expense", $"₹{Model.TotalExpense:N2}"),
    })
    {
        <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-sm-4">
                        <label class="form-label small">From</label>
                        <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small">To</label>
                        <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4">
                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Vouchers</h6>
            </div>
            <div class="card-body">
                @if (!Model.Items.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No vouchers in this date range</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in Model.Items)
                                {
                                    <tr>
                                        <td>@v.Date.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (v.Type == "Receipt")
                                            {
                                                <span class="badge bg-success-subtle text-success">Receipt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger">Payment</span>
                                            }
                                        </td>
                                        <td>@v.Description</td>
                                        <td class="text-end">₹@v.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>New Voucher</h6>
            </div>
            <div class="card-body">
                <form asp-action="SaveVoucher" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select asp-for="Form.Type" class="form-select">
                            <option value="Receipt">Receipt (Income)</option>
                            <option value="Payment">Payment (Expense)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input asp-for="Form.Date" type="date" class="form-control" />
                        <span asp-validation-for="Form.Date" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount</label>
                        <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input asp-for="Form.Description" class="form-control" />
                        <span asp-validation-for="Form.Description" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check2-circle me-1"></i>Save Voucher</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
