@model School.Web.Models.StudentPortal.StudentDashboardViewModel
@{
    ViewData["Title"] = Model.Student.FullName;
    var attendancePct = Model.AttendanceSummary.TotalDays > 0
        ? (Model.AttendanceSummary.PresentDays * 100.0 / Model.AttendanceSummary.TotalDays)
        : 0;
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>@Model.Student.FullName</h6>
            <div class="text-muted small">GR No. @Model.Student.GRNumber &middot; Roll No. @Model.Student.RollNumber</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to My Children</a>
    </div>
</div>

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-calendar-check", "bg-success", "Attendance (this month)", $"{attendancePct:N0}%"),
        ("bi-award",          "bg-primary", "Latest Result",   Model.LatestResult is null ? "—" : $"{Model.LatestResult.Percentage:N1}% ({Model.LatestResult.Grade})"),
        ("bi-cash-stack",     "bg-warning", "Pending Fees",    $"₹{Model.Pending.PendingAmount:N2}"),
        ("bi-book",           "bg-info",    "Books Issued",    Model.ActiveIssuesCount.ToString()),
    })
    {
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-sm-6 col-lg-3">
        <a asp-area="Parent" asp-controller="Attendance" asp-action="Index" asp-route-studentId="@Model.Student.Id"
           class="btn btn-outline-primary w-100 py-3"><i class="bi bi-calendar-check d-block fs-4 mb-1"></i>Attendance</a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-area="Parent" asp-controller="Results" asp-action="Index" asp-route-studentId="@Model.Student.Id"
           class="btn btn-outline-primary w-100 py-3"><i class="bi bi-award d-block fs-4 mb-1"></i>Exam Results</a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-area="Parent" asp-controller="Fees" asp-action="Index" asp-route-studentId="@Model.Student.Id"
           class="btn btn-outline-primary w-100 py-3"><i class="bi bi-cash-stack d-block fs-4 mb-1"></i>Fees</a>
    </div>
    <div class="col-sm-6 col-lg-3">
        <a asp-area="Parent" asp-controller="Library" asp-action="Index" asp-route-studentId="@Model.Student.Id"
           class="btn btn-outline-primary w-100 py-3"><i class="bi bi-book d-block fs-4 mb-1"></i>Library</a>
    </div>
</div>
