@model IReadOnlyList<School.Application.DTOs.Portal.LinkedStudentDto>
@{ ViewData["Title"] = "Parent Portal"; }

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-person-hearts me-2 text-primary"></i>My Children</h6>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-person-hearts" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No child linked to your account yet. Contact the school office.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var child in Model)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>@child.FullName</h6>
                                <div class="text-muted small mb-3">GR No. @child.GRNumber</div>
                                <a asp-action="Child" asp-route-studentId="@child.StudentId" class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
