@model School.Web.Models.Exams.ExamDetailsViewModel
@{ ViewData["Title"] = "Subject Schedule"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-journal-text me-2 text-primary"></i>@Model.ExamName</h6>
            <div class="text-muted small">Subject Schedule</div>
        </div>
        <form method="get" class="d-flex gap-2 align-items-end">
            <input type="hidden" name="examId" value="@Model.ExamId" />
            <div>
                <label class="form-label small">Class</label>
                <select name="classId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select a class</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.SelectedClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Exams</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-list-ul me-2 text-primary"></i>Subjects</h6>
        @if (Model.SelectedClassId.HasValue && Model.Subjects.Any())
        {
            <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                <i class="bi bi-plus-circle me-1"></i>Add New
            </button>
        }
    </div>
    <div class="card-body">
        @if (!Model.SelectedClassId.HasValue)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Select a Class above to view/manage the subject schedule.</p>
            </div>
        }
        else if (!Model.Subjects.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Add subjects for this Class under Masters first.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-journal-text" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No subject schedule yet for this Class</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Max Marks</th>
                            <th>Passing Marks</th>
                            <th>Exam Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@(Model.Subjects.FirstOrDefault(s => s.Id == item.SubjectId)?.Name ?? "—")</td>
                                <td>@item.MaxMarks</td>
                                <td>@item.PassingMarks</td>
                                <td>@item.ExamDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-subjectid="@item.SubjectId"
                                            data-maxmarks="@item.MaxMarks" data-passingmarks="@item.PassingMarks"
                                            data-examdate="@item.ExamDate.ToString("yyyy-MM-dd")"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="DeleteDetail" method="post" class="d-inline" onsubmit="return confirm('Delete this subject schedule entry?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="examId" value="@Model.ExamId" />
                                        <input type="hidden" name="classId" value="@Model.SelectedClassId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="SaveDetail" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalTitle">Add Subject Schedule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <input type="hidden" asp-for="Form.ExamId" value="@Model.ExamId" />
                <input type="hidden" asp-for="Form.ClassId" value="@Model.SelectedClassId" />
                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <select asp-for="Form.SubjectId" class="form-select" id="Form_SubjectId">
                        <option value="">Select a subject</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Form.SubjectId" class="text-danger small"></span>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label">Max Marks</label>
                        <input asp-for="Form.MaxMarks" type="number" step="0.01" class="form-control" id="Form_MaxMarks" />
                        <span asp-validation-for="Form.MaxMarks" class="text-danger small"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label">Passing Marks</label>
                        <input asp-for="Form.PassingMarks" type="number" step="0.01" class="form-control" id="Form_PassingMarks" />
                        <span asp-validation-for="Form.PassingMarks" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Exam Date</label>
                    <input asp-for="Form.ExamDate" type="date" class="form-control" id="Form_ExamDate" />
                    <span asp-validation-for="Form.ExamDate" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const detailModal = new bootstrap.Modal(document.getElementById('detailModal'));

        function openCreateModal() {
            document.getElementById('detailModalTitle').innerText = 'Add Subject Schedule';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_SubjectId').value = '';
            document.getElementById('Form_MaxMarks').value = '';
            document.getElementById('Form_PassingMarks').value = '';
            document.getElementById('Form_ExamDate').value = '';
            detailModal.show();
        }

        function openEditModal(data) {
            document.getElementById('detailModalTitle').innerText = 'Edit Subject Schedule';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_SubjectId').value = data.subjectid;
            document.getElementById('Form_MaxMarks').value = data.maxmarks;
            document.getElementById('Form_PassingMarks').value = data.passingmarks;
            document.getElementById('Form_ExamDate').value = data.examdate;
            detailModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => detailModal.show());</text>
        }
    </script>
}
