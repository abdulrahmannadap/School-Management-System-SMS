@model School.Web.Models.Exams.ExamIndexViewModel
@{ ViewData["Title"] = "Exam Master"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Financial Year</label>
                <select name="financialYearId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select financial year</option>
                    @foreach (var fy in Model.FinancialYears)
                    {
                        <option value="@fy.Id" selected="@(Model.SelectedFinancialYearId == fy.Id)">@fy.Name</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-text me-2 text-primary"></i>Exam Master</h6>
        @if (Model.SelectedFinancialYearId.HasValue)
        {
            <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                <i class="bi bi-plus-circle me-1"></i>Add New
            </button>
        }
    </div>
    <div class="card-body">
        @if (!Model.FinancialYears.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Set up a Financial Year under Masters first.</p>
            </div>
        }
        else if (!Model.SelectedFinancialYearId.HasValue)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Select a Financial Year above to view exams.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-journal-text" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No exams for this Financial Year yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Exam Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ExamName</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsPublished)
                                    {
                                        <span class="badge bg-success-subtle text-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Unpublished</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="Publish" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="financialYearId" value="@Model.SelectedFinancialYearId" />
                                        <input type="hidden" name="isPublished" value="@(!item.IsPublished)" />
                                        <button type="submit" class="btn btn-sm @(item.IsPublished ? "btn-outline-secondary" : "btn-outline-success")">
                                            <i class="bi @(item.IsPublished ? "bi-eye-slash" : "bi-check2-circle")"></i>
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-examname="@item.ExamName"
                                            data-startdate="@item.StartDate.ToString("yyyy-MM-dd")"
                                            data-enddate="@item.EndDate.ToString("yyyy-MM-dd")"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this exam?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="financialYearId" value="@Model.SelectedFinancialYearId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="examModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="examModalTitle">Add Exam</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <input type="hidden" asp-for="Form.FinancialYearId" id="Form_FinancialYearId" value="@Model.SelectedFinancialYearId" />
                <div class="mb-3">
                    <label class="form-label">Exam Name</label>
                    <input asp-for="Form.ExamName" class="form-control" id="Form_ExamName" placeholder="e.g. Mid-Term Exam" />
                    <span asp-validation-for="Form.ExamName" class="text-danger small"></span>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label">Start Date</label>
                        <input asp-for="Form.StartDate" type="date" class="form-control" id="Form_StartDate" />
                        <span asp-validation-for="Form.StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label">End Date</label>
                        <input asp-for="Form.EndDate" type="date" class="form-control" id="Form_EndDate" />
                        <span asp-validation-for="Form.EndDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const examModal = new bootstrap.Modal(document.getElementById('examModal'));

        function openCreateModal() {
            document.getElementById('examModalTitle').innerText = 'Add Exam';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_ExamName').value = '';
            document.getElementById('Form_StartDate').value = '';
            document.getElementById('Form_EndDate').value = '';
            examModal.show();
        }

        function openEditModal(data) {
            document.getElementById('examModalTitle').innerText = 'Edit Exam';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_ExamName').value = data.examname;
            document.getElementById('Form_StartDate').value = data.startdate;
            document.getElementById('Form_EndDate').value = data.enddate;
            examModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => examModal.show());</text>
        }
    </script>
}
