@model School.Web.Models.Exams.ExamResultsViewModel
@{ ViewData["Title"] = "Results"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-award me-2 text-primary"></i>@Model.ExamName</h6>
            <div class="text-muted small">Results</div>
        </div>
        <form method="get" class="d-flex gap-2 align-items-end">
            <input type="hidden" name="examId" value="@Model.ExamId" />
            <div>
                <label class="form-label small">Class</label>
                <select name="classId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select a class</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.SelectedClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
        </form>
        @if (Model.SelectedClassId.HasValue)
        {
            <form asp-action="Generate" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="examId" value="@Model.ExamId" />
                <input type="hidden" name="classId" value="@Model.SelectedClassId" />
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-arrow-repeat me-1"></i>@(Model.Results.Any() ? "Regenerate Results" : "Generate Results")
                </button>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Exams</a>
    </div>
</div>

@if (!Model.SelectedClassId.HasValue)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
            <p class="mt-2 mb-0">Select a Class above to view or generate results.</p>
        </div>
    </div>
}
else if (!Model.Results.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-award" style="font-size:2.5rem;opacity:.3"></i>
            <p class="mt-2 mb-0">No results yet. Make sure marks have been entered, then click "Generate Results".</p>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var stat in new[] {
            ("bi-people-fill", "bg-primary", "Total Students", Model.Summary?.TotalStudents.ToString() ?? "0"),
            ("bi-check-circle", "bg-success", "Passed",         Model.Summary?.Passed.ToString() ?? "0"),
            ("bi-x-circle",     "bg-danger",  "Failed",         Model.Summary?.Failed.ToString() ?? "0"),
        })
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                            <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                        </div>
                        <div>
                            <div class="text-muted small">@stat.Item3</div>
                            <div class="fw-bold fs-4">@stat.Item4</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-list-ol me-2 text-primary"></i>Student Results</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Total Marks</th>
                            <th>Percentage</th>
                            <th>Grade</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Results)
                        {
                            <tr>
                                <td>@(Model.StudentNames.GetValueOrDefault(r.StudentId, "—"))</td>
                                <td>@r.TotalMarks</td>
                                <td>@r.Percentage%</td>
                                <td>@r.Grade</td>
                                <td>
                                    @if (r.IsPass)
                                    {
                                        <span class="badge bg-success-subtle text-success">Pass</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Fail</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
