@model School.Web.Models.Fees.DepositMasterIndexViewModel
@{ ViewData["Title"] = "Deposit Master"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-safe me-2 text-primary"></i>Deposit Master</h6>
        <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
            <i class="bi bi-plus-circle me-1"></i>Add New
        </button>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-safe" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No deposit types set up yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Deposit Name</th>
                            <th>Amount</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.DepositName</td>
                                <td>₹@item.Amount.ToString("N2")</td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-depositname="@item.DepositName" data-amount="@item.Amount"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="DeleteDepositMaster" method="post" class="d-inline" onsubmit="return confirm('Delete this deposit type?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="depositModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="SaveDepositMaster" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="depositModalTitle">Add Deposit Type</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <div class="mb-3">
                    <label class="form-label">Deposit Name</label>
                    <input asp-for="Form.DepositName" class="form-control" id="Form_DepositName" />
                    <span asp-validation-for="Form.DepositName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" id="Form_Amount" />
                    <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const depositModal = new bootstrap.Modal(document.getElementById('depositModal'));

        function openCreateModal() {
            document.getElementById('depositModalTitle').innerText = 'Add Deposit Type';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_DepositName').value = '';
            document.getElementById('Form_Amount').value = '';
            depositModal.show();
        }

        function openEditModal(data) {
            document.getElementById('depositModalTitle').innerText = 'Edit Deposit Type';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_DepositName').value = data.depositname;
            document.getElementById('Form_Amount').value = data.amount;
            depositModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => depositModal.show());</text>
        }
    </script>
}
