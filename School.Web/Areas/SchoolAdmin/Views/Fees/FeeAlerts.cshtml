@model School.Web.Models.Fees.FeeAlertsViewModel
@{ ViewData["Title"] = "Fee Alerts"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Class</label>
                <select name="classId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select a class</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.SelectedClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label small">Financial Year</label>
                <select name="financialYearId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select financial year</option>
                    @foreach (var fy in Model.FinancialYears)
                    {
                        <option value="@fy.Id" selected="@(Model.SelectedFinancialYearId == fy.Id)">@fy.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Load</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-exclamation-triangle me-2 text-primary"></i>Fee Alerts</h6>
    </div>
    <div class="card-body">
        @if (!Model.SelectedClassId.HasValue || !Model.SelectedFinancialYearId.HasValue)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Select a Class and Financial Year above to view fee alerts.</p>
            </div>
        }
        else if (!Model.Alerts.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No pending fees for this Class / Financial Year</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>GR No.</th>
                            <th>Student</th>
                            <th>Alert</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Alerts)
                        {
                            <tr>
                                <td>@a.GRNumber</td>
                                <td>@a.StudentName</td>
                                <td><span class="badge bg-danger-subtle text-danger">@a.Message</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
