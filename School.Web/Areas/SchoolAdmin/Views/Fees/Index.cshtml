@model School.Web.Models.Fees.FeeMasterIndexViewModel
@{ ViewData["Title"] = "Fee Master"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Class</label>
                <select name="classId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select a class</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.SelectedClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label small">Financial Year</label>
                <select name="financialYearId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Select financial year</option>
                    @foreach (var fy in Model.FinancialYears)
                    {
                        <option value="@fy.Id" selected="@(Model.SelectedFinancialYearId == fy.Id)">@fy.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Load</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-collection me-2 text-primary"></i>Fee Master</h6>
        @if (Model.SelectedClassId.HasValue && Model.SelectedFinancialYearId.HasValue)
        {
            <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                <i class="bi bi-plus-circle me-1"></i>Add New
            </button>
        }
    </div>
    <div class="card-body">
        @if (!Model.Classes.Any() || !Model.FinancialYears.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Set up Financial Year and Class under Masters first.</p>
            </div>
        }
        else if (!Model.SelectedClassId.HasValue || !Model.SelectedFinancialYearId.HasValue)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Select a Class and Financial Year above to view fee master records.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-collection" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No fee master records for this Class / Financial Year yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Fee Name</th>
                            <th>Amount</th>
                            <th>Recurring</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.FeeName</td>
                                <td>₹@item.Amount.ToString("N2")</td>
                                <td>
                                    @if (item.IsRecurring)
                                    {
                                        <span class="badge bg-info-subtle text-info">Recurring</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">One-time</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="ApplyToStudents" asp-route-feeMasterId="@item.Id" class="btn btn-sm btn-outline-success" title="Apply to Students">
                                        <i class="bi bi-people"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-feename="@item.FeeName" data-amount="@item.Amount"
                                            data-isrecurring="@item.IsRecurring.ToString().ToLower()"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this fee master record?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="classId" value="@Model.SelectedClassId" />
                                        <input type="hidden" name="financialYearId" value="@Model.SelectedFinancialYearId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="feeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="feeModalTitle">Add Fee Master</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <input type="hidden" asp-for="Form.ClassId" id="Form_ClassId" value="@Model.SelectedClassId" />
                <input type="hidden" asp-for="Form.FinancialYearId" id="Form_FinancialYearId" value="@Model.SelectedFinancialYearId" />
                <div class="mb-3">
                    <label class="form-label">Fee Name</label>
                    <input asp-for="Form.FeeName" class="form-control" id="Form_FeeName" />
                    <span asp-validation-for="Form.FeeName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" id="Form_Amount" />
                    <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                </div>
                <div class="form-check">
                    <input asp-for="Form.IsRecurring" class="form-check-input" id="Form_IsRecurring" />
                    <label class="form-check-label" asp-for="Form.IsRecurring">Recurring</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const feeModal = new bootstrap.Modal(document.getElementById('feeModal'));

        function openCreateModal() {
            document.getElementById('feeModalTitle').innerText = 'Add Fee Master';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_FeeName').value = '';
            document.getElementById('Form_Amount').value = '';
            document.getElementById('Form_IsRecurring').checked = false;
            feeModal.show();
        }

        function openEditModal(data) {
            document.getElementById('feeModalTitle').innerText = 'Edit Fee Master';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_FeeName').value = data.feename;
            document.getElementById('Form_Amount').value = data.amount;
            document.getElementById('Form_IsRecurring').checked = data.isrecurring === 'true';
            feeModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => feeModal.show());</text>
        }
    </script>
}
