@model School.Web.Models.Inventory.ExpensesIndexViewModel
@{ ViewData["Title"] = "Expenses"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-sm-4">
                        <label class="form-label small">From</label>
                        <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small">To</label>
                        <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-sm-4 d-flex gap-2">
                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                        <button type="button" class="btn btn-sm btn-primary ms-auto" onclick="expenseModal.show()"><i class="bi bi-plus-circle me-1"></i>Add Expense</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-wallet2 me-2 text-primary"></i>Expenses</h6>
            </div>
            <div class="card-body">
                @if (!Model.Items.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No expenses in this date range</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Expense</th>
                                    <th>Category</th>
                                    <th class="text-end">Amount</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in Model.Items)
                                {
                                    <tr>
                                        <td>@e.Date.ToString("dd MMM yyyy")</td>
                                        <td>@e.ExpenseName</td>
                                        <td><span class="badge bg-secondary-subtle text-secondary">@e.Category</span></td>
                                        <td class="text-end">₹@e.Amount.ToString("N2")</td>
                                        <td class="text-end">
                                            <form asp-action="DeleteExpense" method="post" class="d-inline" onsubmit="return confirm('Delete this expense?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@e.Id" />
                                                <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
                                                <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2 text-primary"></i>By Category</h6>
            </div>
            <div class="card-body">
                @if (!Model.Summary.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No data</p>
                }
                else
                {
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                            @foreach (var s in Model.Summary)
                            {
                                <tr>
                                    <td>@s.Category <span class="text-muted small">(@s.Count)</span></td>
                                    <td class="text-end">₹@s.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="expenseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="SaveExpense" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
            <div class="modal-header">
                <h5 class="modal-title">Add Expense</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Expense Name</label>
                    <input asp-for="Form.ExpenseName" class="form-control" />
                    <span asp-validation-for="Form.ExpenseName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input asp-for="Form.Amount" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Form.Amount" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Date</label>
                    <input asp-for="Form.Date" type="date" class="form-control" />
                    <span asp-validation-for="Form.Date" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Category</label>
                    <input asp-for="Form.Category" class="form-control" placeholder="e.g. Utilities, Maintenance" />
                    <span asp-validation-for="Form.Category" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const expenseModal = new bootstrap.Modal(document.getElementById('expenseModal'));
        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => expenseModal.show());</text>
        }
    </script>
}
