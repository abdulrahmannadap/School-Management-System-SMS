@model School.Web.Models.Inventory.InvoiceDetailViewModel
@{ ViewData["Title"] = "Invoice Detail"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-receipt me-2 text-primary"></i>@Model.Invoice.InvoiceNo</h6>
            <div class="text-muted small">@Model.Invoice.CustomerName &middot; @Model.Invoice.Date.ToString("dd MMM yyyy")</div>
        </div>
        <a asp-action="Invoices" class="btn btn-outline-secondary btn-sm">Back to Invoices</a>
    </div>
</div>

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-cash-stack",    "bg-primary", "Total Amount", $"₹{Model.Invoice.TotalAmount:N2}"),
        ("bi-check2-circle", "bg-success", "Paid",         $"₹{Model.Invoice.PaidAmount:N2}"),
        ("bi-clock-history", "bg-danger",  "Pending",      $"₹{Model.Invoice.PendingAmount:N2}"),
    })
    {
        <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-list-ul me-2 text-primary"></i>Line Items</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Rate</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Invoice.Items)
                            {
                                <tr>
                                    <td>@(Model.Products.FirstOrDefault(p => p.Id == item.ProductId)?.Name ?? "—")</td>
                                    <td class="text-end">@item.Quantity.ToString("N2")</td>
                                    <td class="text-end">₹@item.Rate.ToString("N2")</td>
                                    <td class="text-end">₹@item.Amount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Payment History</h6>
            </div>
            <div class="card-body">
                @if (!Model.CreditPayments.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No credit payments recorded yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Mode</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.CreditPayments)
                                {
                                    <tr>
                                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                        <td>@p.PaymentMode</td>
                                        <td class="text-end">₹@p.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        @if (Model.Invoice.Status != "Cancelled" && Model.Invoice.PendingAmount > 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-cash-coin me-2 text-primary"></i>Record Payment</h6>
                </div>
                <div class="card-body">
                    <form asp-action="RecordCreditPayment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="PaymentForm.InvoiceId" />
                        <div class="mb-3">
                            <label class="form-label">Amount</label>
                            <input asp-for="PaymentForm.Amount" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="PaymentForm.Amount" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payment Date</label>
                            <input asp-for="PaymentForm.PaymentDate" type="date" class="form-control" />
                            <span asp-validation-for="PaymentForm.PaymentDate" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Payment Mode</label>
                            <select asp-for="PaymentForm.PaymentMode" class="form-select">
                                <option value="">Select mode</option>
                                <option value="Cash">Cash</option>
                                <option value="Card">Card</option>
                                <option value="Bank">Bank</option>
                                <option value="Online">Online</option>
                            </select>
                            <span asp-validation-for="PaymentForm.PaymentMode" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check2-circle me-1"></i>Record Payment</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-muted py-5">
                    <i class="bi bi-check-circle" style="font-size:2.5rem;opacity:.3"></i>
                    <p class="mt-2 mb-0">This invoice is fully settled</p>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
