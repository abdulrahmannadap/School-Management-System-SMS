@model School.Web.Models.Inventory.InvoicesIndexViewModel
@{ ViewData["Title"] = "Invoices"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">From</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-4">
                <label class="form-label small">To</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-4 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a asp-action="NewInvoice" class="btn btn-sm btn-primary ms-auto"><i class="bi bi-plus-circle me-1"></i>New Invoice</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-receipt me-2 text-primary"></i>Invoices</h6>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <p class="text-muted text-center py-3 mb-0">No invoices in this date range</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Invoice No.</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Pending</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Items)
                        {
                            <tr>
                                <td>@inv.InvoiceNo</td>
                                <td>@inv.Date.ToString("dd MMM yyyy")</td>
                                <td>@inv.CustomerName</td>
                                <td class="text-end">₹@inv.TotalAmount.ToString("N2")</td>
                                <td class="text-end">₹@inv.PaidAmount.ToString("N2")</td>
                                <td class="text-end">₹@inv.PendingAmount.ToString("N2")</td>
                                <td>
                                    @{
                                        var badgeClass = inv.Status switch
                                        {
                                            "Paid" => "bg-success-subtle text-success",
                                            "Partial" => "bg-warning-subtle text-warning",
                                            "Cancelled" => "bg-secondary-subtle text-secondary",
                                            _ => "bg-danger-subtle text-danger"
                                        };
                                    }
                                    <span class="badge @badgeClass">@inv.Status</span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="InvoiceDetail" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
