@model School.Web.Models.Inventory.ProductsIndexViewModel
@{ ViewData["Title"] = "Products"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Category</label>
                <select name="categoryId" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.SelectedCategoryId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-4 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-funnel me-1"></i>Filter</button>
                <a asp-action="Products" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-boxes me-2 text-primary"></i>Products</h6>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="categoryModal.show()">
                <i class="bi bi-tags me-1"></i>Manage Categories
            </button>
            @if (Model.Categories.Any())
            {
                <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                    <i class="bi bi-plus-circle me-1"></i>Add New
                </button>
            }
        </div>
    </div>
    <div class="card-body">
        @if (!Model.Categories.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Add a Category first before adding products.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-boxes" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No products yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Purchase Price</th>
                            <th>Selling Price</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@(Model.Categories.FirstOrDefault(c => c.Id == item.CategoryId)?.Name ?? "—")</td>
                                <td>₹@item.PurchasePrice.ToString("N2")</td>
                                <td>₹@item.SellingPrice.ToString("N2")</td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-name="@item.Name" data-categoryid="@item.CategoryId"
                                            data-purchaseprice="@item.PurchasePrice" data-sellingprice="@item.SellingPrice"
                                            data-isactive="@item.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="DeleteProduct" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this product? It will no longer be visible or editable anywhere in the system.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form asp-action="SaveProduct" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="productModalTitle">Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Name</label>
                        <input asp-for="Form.Name" class="form-control" id="Form_Name" />
                        <span asp-validation-for="Form.Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category</label>
                        <select asp-for="Form.CategoryId" class="form-select" id="Form_CategoryId">
                            <option value="">Select a category</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.CategoryId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Purchase Price</label>
                        <input asp-for="Form.PurchasePrice" type="number" step="0.01" class="form-control" id="Form_PurchasePrice" />
                        <span asp-validation-for="Form.PurchasePrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Selling Price</label>
                        <input asp-for="Form.SellingPrice" type="number" step="0.01" class="form-control" id="Form_SellingPrice" />
                        <span asp-validation-for="Form.SellingPrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3 form-check pt-4">
                        <input asp-for="Form.IsActive" class="form-check-input" id="Form_IsActive" />
                        <label class="form-check-label" asp-for="Form.IsActive">Active</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="categoriesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manage Categories</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @if (Model.Categories.Any())
                {
                    <ul class="list-group mb-3">
                        @foreach (var c in Model.Categories)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @c.Name
                                <span>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@c.Id" data-name="@c.Name"
                                            onclick="openEditCategory(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="DeleteCategory" method="post" class="d-inline" onsubmit="return confirm('Delete this category?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </span>
                            </li>
                        }
                    </ul>
                }
                <form asp-action="SaveCategory" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CategoryForm.Id" id="CategoryForm_Id" />
                    <input asp-for="CategoryForm.Name" id="CategoryForm_Name" class="form-control" placeholder="Category name" />
                    <button type="submit" class="btn btn-primary text-nowrap" id="categorySubmitBtn">Add</button>
                </form>
                <span asp-validation-for="CategoryForm.Name" class="text-danger small"></span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const productModal = new bootstrap.Modal(document.getElementById('productModal'));
        const categoryModal = new bootstrap.Modal(document.getElementById('categoriesModal'));

        function openCreateModal() {
            document.getElementById('productModalTitle').innerText = 'Add Product';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_Name').value = '';
            document.getElementById('Form_CategoryId').value = '';
            document.getElementById('Form_PurchasePrice').value = '';
            document.getElementById('Form_SellingPrice').value = '';
            document.getElementById('Form_IsActive').checked = true;
            productModal.show();
        }

        function openEditModal(data) {
            document.getElementById('productModalTitle').innerText = 'Edit Product';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_Name').value = data.name;
            document.getElementById('Form_CategoryId').value = data.categoryid;
            document.getElementById('Form_PurchasePrice').value = data.purchaseprice;
            document.getElementById('Form_SellingPrice').value = data.sellingprice;
            document.getElementById('Form_IsActive').checked = data.isactive === 'true';
            productModal.show();
        }

        function openEditCategory(data) {
            document.getElementById('CategoryForm_Id').value = data.id;
            document.getElementById('CategoryForm_Name').value = data.name;
            document.getElementById('categorySubmitBtn').innerText = 'Update';
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => productModal.show());</text>
        }
        @if (Model.ShowCategoryModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => categoryModal.show());</text>
        }
    </script>
}
