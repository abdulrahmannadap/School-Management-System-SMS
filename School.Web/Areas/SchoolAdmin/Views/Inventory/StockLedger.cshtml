@model School.Web.Models.Inventory.StockLedgerViewModel
@{ ViewData["Title"] = "Stock Ledger"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-boxes me-2 text-primary"></i>Stock Balances</h6>
            </div>
            <div class="card-body">
                @if (!Model.Balances.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No products yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-end">In</th>
                                    <th class="text-end">Out</th>
                                    <th class="text-end">Current Stock</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.Balances)
                                {
                                    <tr class="@(Model.SelectedProductId == b.ProductId ? "table-active" : "")">
                                        <td>@b.ProductName</td>
                                        <td class="text-end">@b.TotalIn.ToString("N2")</td>
                                        <td class="text-end">@b.TotalOut.ToString("N2")</td>
                                        <td class="text-end fw-semibold">@b.CurrentStock.ToString("N2")</td>
                                        <td class="text-end">
                                            <a asp-action="StockLedger" asp-route-productId="@b.ProductId" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @if (Model.SelectedProductId.HasValue)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Ledger &mdash; @Model.SelectedBalance?.ProductName</h6>
                </div>
                <div class="card-body">
                    @if (!Model.Ledger.Any())
                    {
                        <p class="text-muted text-center py-3 mb-0">No stock movements yet</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th class="text-end">In</th>
                                        <th class="text-end">Out</th>
                                        <th>Reference</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in Model.Ledger)
                                    {
                                        <tr>
                                            <td>@l.Date.ToString("dd MMM yyyy")</td>
                                            <td>@l.Type</td>
                                            <td class="text-end">@(l.InQty > 0 ? l.InQty.ToString("N2") : "—")</td>
                                            <td class="text-end">@(l.OutQty > 0 ? l.OutQty.ToString("N2") : "—")</td>
                                            <td>@l.ReferenceNo</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Stock Entry</h6>
            </div>
            <div class="card-body">
                <form asp-action="AddStockEntry" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Product</label>
                        <select asp-for="Form.ProductId" class="form-select">
                            <option value="">Select product</option>
                            @foreach (var p in Model.Products)
                            {
                                <option value="@p.Id" selected="@(Model.SelectedProductId == p.Id)">@p.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.ProductId" class="text-danger small"></span>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">In Qty</label>
                            <input asp-for="Form.InQty" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Form.InQty" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Out Qty</label>
                            <input asp-for="Form.OutQty" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Form.OutQty" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input asp-for="Form.Date" type="date" class="form-control" />
                        <span asp-validation-for="Form.Date" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select asp-for="Form.Type" class="form-select">
                            <option value="Purchase">Purchase</option>
                            <option value="Adjustment">Adjustment</option>
                            <option value="Return">Return</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reference No.</label>
                        <input asp-for="Form.ReferenceNo" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check2-circle me-1"></i>Record Entry</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
