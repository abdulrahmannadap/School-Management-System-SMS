@model School.Web.Models.Library.BorrowerDetailViewModel
@{ ViewData["Title"] = "Issue / Return"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>@Model.PersonName</h6>
            <div class="text-muted small">@(Model.BorrowerType == "Staff" ? "Employee Code" : "GR No."). @Model.PersonCode &middot; @Model.BorrowerType</div>
        </div>
        <a asp-action="IssueReturn" asp-route-borrowerType="@Model.BorrowerType" class="btn btn-outline-secondary btn-sm">Back to Search</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Currently Issued Books</h6>
            </div>
            <div class="card-body">
                @if (!Model.ActiveIssues.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No books currently issued</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Book</th>
                                    <th>Issue Date</th>
                                    <th>Due Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in Model.ActiveIssues)
                                {
                                    var isOverdue = issue.DueDate.Date < DateTime.Today;
                                    <tr>
                                        <td>@issue.BookTitle</td>
                                        <td>@issue.IssueDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @issue.DueDate.ToString("dd MMM yyyy")
                                            @if (isOverdue)
                                            {
                                                <span class="badge bg-danger-subtle text-danger ms-1">Overdue</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-success"
                                                    data-id="@issue.Id"
                                                    onclick="openReturnModal(this.dataset.id)">
                                                <i class="bi bi-check2-circle me-1"></i>Return
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>Issue a Book</h6>
            </div>
            <div class="card-body">
                @if (!Model.AvailableBooks.Any())
                {
                    <p class="text-muted small mb-0">No books with available copies right now.</p>
                }
                else
                {
                    <form asp-action="IssueBook" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="IssueForm.PersonId" />
                        <input type="hidden" asp-for="IssueForm.BorrowerType" />
                        <div class="mb-3">
                            <label class="form-label">Book</label>
                            <select asp-for="IssueForm.BookId" class="form-select">
                                <option value="">Select book</option>
                                @foreach (var b in Model.AvailableBooks)
                                {
                                    <option value="@b.Id">@b.Title (@b.AvailableQuantity available)</option>
                                }
                            </select>
                            <span asp-validation-for="IssueForm.BookId" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Issue Date</label>
                            <input asp-for="IssueForm.IssueDate" type="date" class="form-control" />
                            <span asp-validation-for="IssueForm.IssueDate" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Due Date</label>
                            <input asp-for="IssueForm.DueDate" type="date" class="form-control" />
                            <span asp-validation-for="IssueForm.DueDate" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check2-circle me-1"></i>Issue Book</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="ReturnBook" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnForm.PersonId" />
            <input type="hidden" asp-for="ReturnForm.BorrowerType" />
            <input type="hidden" asp-for="ReturnForm.IssueId" id="ReturnForm_IssueId" />
            <div class="modal-header">
                <h5 class="modal-title">Return Book</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Return Date</label>
                    <input asp-for="ReturnForm.ReturnDate" type="date" class="form-control" />
                    <span asp-validation-for="ReturnForm.ReturnDate" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Fine Amount</label>
                    <input asp-for="ReturnForm.FineAmount" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="ReturnForm.FineAmount" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Confirm Return</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const returnModal = new bootstrap.Modal(document.getElementById('returnModal'));
        function openReturnModal(issueId) {
            document.getElementById('ReturnForm_IssueId').value = issueId;
            returnModal.show();
        }
    </script>
}
