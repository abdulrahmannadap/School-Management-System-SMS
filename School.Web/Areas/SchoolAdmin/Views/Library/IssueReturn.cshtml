@model School.Web.Models.Library.BorrowerSearchViewModel
@{ ViewData["Title"] = "Issue / Return"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">Borrower Type</label>
                <select name="borrowerType" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="Student" selected="@(Model.BorrowerType == "Student")">Student</option>
                    <option value="Staff" selected="@(Model.BorrowerType == "Staff")">Staff</option>
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label small">Name</label>
                <input type="text" name="name" value="@Model.Name" class="form-control form-control-sm" placeholder="Search by name" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">@(Model.BorrowerType == "Staff" ? "Employee Code" : "GR Number")</label>
                <input type="text" name="code" value="@Model.Code" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <button type="submit" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-search me-1"></i>Search</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-arrow-left-right me-2 text-primary"></i>Search Results</h6>
    </div>
    <div class="card-body">
        @if (!Model.Results.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-search" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Search by name or code above to find a @Model.BorrowerType.ToLower() and manage book issues/returns.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>@(Model.BorrowerType == "Staff" ? "Employee Code" : "GR Number")</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Results)
                        {
                            <tr>
                                <td>@r.Name</td>
                                <td>@r.Code</td>
                                <td class="text-end">
                                    <a asp-action="BorrowerDetail" asp-route-personId="@r.Id" asp-route-borrowerType="@Model.BorrowerType" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-book me-1"></i>Manage Books
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
