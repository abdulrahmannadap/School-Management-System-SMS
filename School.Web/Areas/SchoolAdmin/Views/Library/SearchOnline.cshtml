@model School.Web.Models.Library.SearchOnlineViewModel
@{ ViewData["Title"] = "Search Online"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <form method="get" class="d-flex gap-2 flex-grow-1 me-3">
            <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by title or author (e.g. mathematics, shakespeare)" />
            <button type="submit" class="btn btn-primary text-nowrap"><i class="bi bi-search me-1"></i>Search</button>
        </form>
        <a asp-action="Books" class="btn btn-outline-secondary text-nowrap">Back to Books</a>
    </div>
</div>

@if (Model.Warnings.Any())
{
    @foreach (var warning in Model.Warnings)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@warning
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-globe me-2 text-primary"></i>Results</h6>
    </div>
    <div class="card-body">
        @if (string.IsNullOrWhiteSpace(Model.Query))
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-search" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Enter a title or author above to search Open Library, Google Books, and Project Gutenberg.</p>
            </div>
        }
        else if (!Model.Results.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-emoji-frown" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No results found for "@Model.Query"</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var result in Model.Results)
                {
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex gap-2 mb-2">
                                    @if (!string.IsNullOrEmpty(result.CoverUrl))
                                    {
                                        <img src="@result.CoverUrl" alt="" style="width:48px;height:64px;object-fit:cover;" class="rounded" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:48px;height:64px;">
                                            <i class="bi bi-book text-muted"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small">@result.Title</div>
                                        <div class="text-muted small">@result.Author</div>
                                    </div>
                                </div>
                                <span class="badge bg-primary-subtle text-primary mb-2 align-self-start">@result.Source</span>
                                <div class="mt-auto d-flex gap-2">
                                    @if (!string.IsNullOrEmpty(result.InfoLink))
                                    {
                                        <a href="@result.InfoLink" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary flex-fill">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>View
                                        </a>
                                    }
                                    <a asp-action="Books" asp-route-prefillTitle="@result.Title" asp-route-prefillAuthor="@result.Author" class="btn btn-sm btn-primary flex-fill">
                                        <i class="bi bi-plus-circle me-1"></i>Add
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
