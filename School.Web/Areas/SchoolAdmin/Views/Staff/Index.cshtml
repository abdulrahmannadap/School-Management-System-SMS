@model School.Web.Models.Staff.StaffIndexViewModel
@{ ViewData["Title"] = "Staff"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Name</label>
                <input type="text" name="Name" value="@Model.Search.Name" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Employee Code</label>
                <input type="text" name="EmployeeCode" value="@Model.Search.EmployeeCode" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Designation</label>
                <input type="text" name="Designation" value="@Model.Search.Designation" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-person-badge me-2 text-primary"></i>Staff</h6>
        <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
            <i class="bi bi-person-plus me-1"></i>Add New
        </button>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-person-badge" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No staff found</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Emp. Code</th>
                            <th>Name</th>
                            <th>Designation</th>
                            <th>Mobile</th>
                            <th>Joining Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.EmployeeCode</td>
                                <td>@item.FullName</td>
                                <td>@item.Designation</td>
                                <td>@item.Mobile</td>
                                <td>@item.JoiningDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-fullname="@item.FullName" data-mobile="@item.Mobile"
                                            data-designation="@item.Designation" data-email="@item.Email"
                                            data-isactive="@item.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (item.IsActive)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Deactivate this staff member? Their record is kept but marked inactive.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate"><i class="bi bi-person-dash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="staffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <h5 class="mb-3" id="staffModalTitle">Add Staff</h5>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Full Name</label>
                        <input asp-for="Form.FullName" class="form-control" id="Form_FullName" />
                        <span asp-validation-for="Form.FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Mobile</label>
                        <input asp-for="Form.Mobile" class="form-control" id="Form_Mobile" />
                        <span asp-validation-for="Form.Mobile" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Designation</label>
                        <input asp-for="Form.Designation" class="form-control" id="Form_Designation" />
                        <span asp-validation-for="Form.Designation" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3" id="joiningDateField">
                        <label class="form-label">Joining Date</label>
                        <input asp-for="Form.JoiningDate" type="date" class="form-control" id="Form_JoiningDate" />
                        <span asp-validation-for="Form.JoiningDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3" id="loginRoleField">
                        <label class="form-label">Login Role</label>
                        <select asp-for="Form.LoginRole" class="form-select" id="Form_LoginRole">
                            <option value="Teacher">Teacher</option>
                            <option value="Accountant">Accountant</option>
                            <option value="Staff">Staff</option>
                        </select>
                        <div class="form-text">Determines which area this person's login can access.</div>
                    </div>
                    <div class="col-md-6 mb-3" id="emailField">
                        <label class="form-label">Email</label>
                        <input asp-for="Form.Email" class="form-control" id="Form_Email" />
                        <span asp-validation-for="Form.Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3 form-check pt-4" id="isActiveField">
                        <input asp-for="Form.IsActive" class="form-check-input" id="Form_IsActive" />
                        <label class="form-check-label" asp-for="Form.IsActive">Active</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const staffModal = new bootstrap.Modal(document.getElementById('staffModal'));

        function toggleCreateOnlyFields(isCreate) {
            document.getElementById('joiningDateField').style.display = isCreate ? '' : 'none';
            document.getElementById('loginRoleField').style.display = isCreate ? '' : 'none';
            document.getElementById('emailField').style.display = isCreate ? 'none' : '';
            document.getElementById('isActiveField').style.display = isCreate ? 'none' : '';
        }

        function openCreateModal() {
            document.getElementById('staffModalTitle').innerText = 'Add Staff';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_FullName').value = '';
            document.getElementById('Form_Mobile').value = '';
            document.getElementById('Form_Designation').value = '';
            document.getElementById('Form_JoiningDate').value = '';
            document.getElementById('Form_LoginRole').value = 'Staff';
            document.getElementById('Form_Email').value = '';
            document.getElementById('Form_IsActive').checked = false;
            toggleCreateOnlyFields(true);
            staffModal.show();
        }

        function openEditModal(data) {
            document.getElementById('staffModalTitle').innerText = 'Edit Staff';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_FullName').value = data.fullname;
            document.getElementById('Form_Mobile').value = data.mobile;
            document.getElementById('Form_Designation').value = data.designation;
            document.getElementById('Form_Email').value = data.email;
            document.getElementById('Form_IsActive').checked = data.isactive === 'true';
            toggleCreateOnlyFields(false);
            staffModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => { toggleCreateOnlyFields(@(Model.Form.Id == 0 ? "true" : "false")); staffModal.show(); });</text>
        }
    </script>
}
