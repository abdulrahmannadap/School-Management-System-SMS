@model School.Web.Models.Students.StudentsIndexViewModel
@{ ViewData["Title"] = "Students"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">Name</label>
                <input type="text" name="Name" value="@Model.Search.Name" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">GR Number</label>
                <input type="text" name="GRNumber" value="@Model.Search.GRNumber" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Class</label>
                <select name="ClassId" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.Search.ClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Division</label>
                <select name="DivisionId" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var d in Model.Divisions)
                    {
                        <option value="@d.Id" selected="@(Model.Search.DivisionId == d.Id)">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-people-fill me-2 text-primary"></i>Students</h6>
        @if (Model.Classes.Any() && Model.Divisions.Any() && Model.FinancialYears.Any())
        {
            <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                <i class="bi bi-person-plus me-1"></i>Add New
            </button>
        }
    </div>
    <div class="card-body">
        @if (!Model.Classes.Any() || !Model.Divisions.Any() || !Model.FinancialYears.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Set up Financial Year, Class and Division under Masters first.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-people" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No students found</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>GR No.</th>
                            <th>Name</th>
                            <th>Class / Division</th>
                            <th>Gender</th>
                            <th>DOB</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.GRNumber</td>
                                <td>@item.FullName</td>
                                <td>
                                    @(Model.Classes.FirstOrDefault(c => c.Id == item.ClassId)?.Name ?? "—")
                                    / @(Model.Divisions.FirstOrDefault(d => d.Id == item.DivisionId)?.Name ?? "—")
                                </td>
                                <td>@item.Gender</td>
                                <td>@item.DateOfBirth.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@item.Id" data-classid="@item.ClassId" data-divisionid="@item.DivisionId"
                                            data-fullname="@item.FullName" data-gender="@item.Gender"
                                            data-dob="@item.DateOfBirth.ToString("yyyy-MM-dd")" data-email="@item.Email"
                                            data-isactive="@item.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (item.IsActive)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Deactivate this student? Their record is kept but marked inactive.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate"><i class="bi bi-person-dash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="studentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="studentModalTitle">Add Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <div class="row">
                    <div class="col-md-6 mb-3" id="fyField">
                        <label class="form-label">Financial Year</label>
                        <select asp-for="Form.FinancialYearId" class="form-select" id="Form_FinancialYearId">
                            <option value="">Select financial year</option>
                            @foreach (var fy in Model.FinancialYears)
                            {
                                <option value="@fy.Id">@fy.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.FinancialYearId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Full Name</label>
                        <input asp-for="Form.FullName" class="form-control" id="Form_FullName" />
                        <span asp-validation-for="Form.FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Class</label>
                        <select asp-for="Form.ClassId" class="form-select" id="Form_ClassId">
                            <option value="">Select a class</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.ClassId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Division</label>
                        <select asp-for="Form.DivisionId" class="form-select" id="Form_DivisionId">
                            <option value="">Select a division</option>
                            @foreach (var d in Model.Divisions)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.DivisionId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Gender</label>
                        <select asp-for="Form.Gender" class="form-select" id="Form_Gender">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Form.Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Date of Birth</label>
                        <input asp-for="Form.DateOfBirth" type="date" class="form-control" id="Form_DateOfBirth" />
                        <span asp-validation-for="Form.DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3" id="emailField">
                        <label class="form-label">Email</label>
                        <input asp-for="Form.Email" class="form-control" id="Form_Email" />
                        <span asp-validation-for="Form.Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3" id="fatherNameField">
                        <label class="form-label">Father's Name</label>
                        <input asp-for="Form.FatherName" class="form-control" id="Form_FatherName" />
                    </div>
                    <div class="col-md-4 mb-3" id="fatherMobileField">
                        <label class="form-label">Father's Mobile</label>
                        <input asp-for="Form.FatherMobile" class="form-control" id="Form_FatherMobile" />
                    </div>
                    <div class="col-md-4 mb-3 form-check pt-4" id="isActiveField">
                        <input asp-for="Form.IsActive" class="form-check-input" id="Form_IsActive" />
                        <label class="form-check-label" asp-for="Form.IsActive">Active</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const studentModal = new bootstrap.Modal(document.getElementById('studentModal'));

        function toggleCreateOnlyFields(isCreate) {
            document.getElementById('fyField').style.display = isCreate ? '' : 'none';
            document.getElementById('fatherNameField').style.display = isCreate ? '' : 'none';
            document.getElementById('fatherMobileField').style.display = isCreate ? '' : 'none';
            document.getElementById('emailField').style.display = isCreate ? 'none' : '';
            document.getElementById('isActiveField').style.display = isCreate ? 'none' : '';
        }

        function openCreateModal() {
            document.getElementById('studentModalTitle').innerText = 'Add Student';
            document.getElementById('Form_Id').value = 0;
            document.getElementById('Form_FinancialYearId').value = '';
            document.getElementById('Form_ClassId').value = '';
            document.getElementById('Form_DivisionId').value = '';
            document.getElementById('Form_FullName').value = '';
            document.getElementById('Form_Gender').value = '';
            document.getElementById('Form_DateOfBirth').value = '';
            document.getElementById('Form_Email').value = '';
            document.getElementById('Form_FatherName').value = '';
            document.getElementById('Form_FatherMobile').value = '';
            document.getElementById('Form_IsActive').checked = false;
            toggleCreateOnlyFields(true);
            studentModal.show();
        }

        function openEditModal(data) {
            document.getElementById('studentModalTitle').innerText = 'Edit Student';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_ClassId').value = data.classid;
            document.getElementById('Form_DivisionId').value = data.divisionid;
            document.getElementById('Form_FullName').value = data.fullname;
            document.getElementById('Form_Gender').value = data.gender;
            document.getElementById('Form_DateOfBirth').value = data.dob;
            document.getElementById('Form_Email').value = data.email;
            document.getElementById('Form_IsActive').checked = data.isactive === 'true';
            toggleCreateOnlyFields(false);
            studentModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => { toggleCreateOnlyFields(@(Model.Form.Id == 0 ? "true" : "false")); studentModal.show(); });</text>
        }
    </script>
}
