@model School.Web.Models.StudentPortal.StudentFeesViewModel
@{ ViewData["Title"] = "Fees"; }

<div class="row g-3 mb-4">
    @foreach (var stat in new[] {
        ("bi-receipt",       "bg-primary", "Total Fees",     $"₹{Model.Pending.TotalFees:N2}"),
        ("bi-cash-stack",    "bg-success", "Paid",           $"₹{Model.Pending.PaidAmount:N2}"),
        ("bi-clock-history", "bg-danger",  "Pending",        $"₹{Model.Pending.PendingAmount:N2}"),
    })
    {
        <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                        <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">@stat.Item3</div>
                        <div class="fw-bold fs-4">@stat.Item4</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Fee Ledger</h6>
            </div>
            <div class="card-body">
                @if (!Model.Ledger.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No ledger entries yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th class="text-end">Debit</th>
                                    <th class="text-end">Credit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.Ledger)
                                {
                                    <tr>
                                        <td>@entry.Date.ToString("dd MMM yyyy")</td>
                                        <td>@entry.Type</td>
                                        <td class="text-end">@(entry.Debit > 0 ? $"₹{entry.Debit:N2}" : "—")</td>
                                        <td class="text-end">@(entry.Credit > 0 ? $"₹{entry.Credit:N2}" : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Payment History</h6>
            </div>
            <div class="card-body">
                @if (!Model.Payments.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No payments recorded yet</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Mode</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Payments)
                                {
                                    <tr>
                                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                        <td>@p.PaymentMode</td>
                                        <td class="text-end">₹@p.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
