@model School.Web.Models.StudentPortal.StudentResultDetailViewModel
@{ ViewData["Title"] = "Result Detail"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h6 class="fw-semibold mb-1"><i class="bi bi-award me-2 text-primary"></i>@Model.Exam.ExamName</h6>
            <div class="text-muted small">@Model.Exam.StartDate.ToString("dd MMM yyyy") &ndash; @Model.Exam.EndDate.ToString("dd MMM yyyy")</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Results</a>
    </div>
</div>

@if (Model.Result is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-hourglass-split" style="font-size:2.5rem;opacity:.3"></i>
            <p class="mt-2 mb-0">Result not generated yet for this exam</p>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var stat in new[] {
            ("bi-sum",            "bg-primary", "Total Marks", Model.Result.TotalMarks.ToString("N2")),
            ("bi-percent",        "bg-info",    "Percentage",  $"{Model.Result.Percentage:N2}%"),
            ("bi-patch-check",    "bg-success", "Grade",       Model.Result.Grade),
            (Model.Result.IsPass ? "bi-check2-circle" : "bi-x-circle",
                                  Model.Result.IsPass ? "bg-success" : "bg-danger",
                                  "Status", Model.Result.IsPass ? "Pass" : "Fail"),
        })
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                            <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                        </div>
                        <div>
                            <div class="text-muted small">@stat.Item3</div>
                            <div class="fw-bold fs-4">@stat.Item4</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-list-ul me-2 text-primary"></i>Subject-wise Marks</h6>
    </div>
    <div class="card-body">
        @if (!Model.Marks.Any())
        {
            <p class="text-muted text-center py-3 mb-0">No marks entered yet</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th class="text-end">Marks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.Marks)
                        {
                            <tr>
                                <td>@Model.SubjectNames.GetValueOrDefault(m.SubjectId, "—")</td>
                                <td class="text-end">@(m.IsAbsent ? "Absent" : m.MarksObtained.ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
