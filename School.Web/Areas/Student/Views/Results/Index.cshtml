@model School.Web.Models.StudentPortal.StudentResultsViewModel
@{ ViewData["Title"] = "Exam Results"; }

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-award me-2 text-primary"></i>Published Results</h6>
    </div>
    <div class="card-body">
        @if (!Model.Exams.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-award" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No published exam results yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Exam</th>
                            <th>Period</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in Model.Exams)
                        {
                            <tr>
                                <td>@exam.ExamName</td>
                                <td>@exam.StartDate.ToString("dd MMM yyyy") &ndash; @exam.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end">
                                    <a asp-action="Detail" asp-route-examId="@exam.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View Result
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
