@{ Layout = "~/Views/Shared/_BaseLayout.cshtml"; }
@section Sidebar {
    <nav id="sidebar" class="sidebar" aria-label="Main navigation">
        <button type="button" id="sidebarCollapseToggle" class="sidebar-toggle-btn"
                aria-label="Collapse sidebar" aria-pressed="false" title="Collapse sidebar">
            <i class="bi bi-chevron-left"></i>
        </button>

        <a class="sidebar-brand" href="#">
            <img src="~/images/logo_ii.jpeg" asp-append-version="true" alt="@(ViewData["EffectiveSchoolName"]) Logo" class="brand-logo" />

            <div class="brand-text">
                <div class="brand-name">@ViewData["EffectiveSchoolName"]</div>
                <div class="brand-sub">School Management</div>
            </div>
        </a>

        <ul class="sidebar-nav list-unstyled mb-0">
            <partial name="~/Views/Shared/_DynamicSidebar.cshtml" />
        </ul>
    </nav>
}
@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
@RenderBody()
