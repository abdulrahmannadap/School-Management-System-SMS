@model School.Web.Models.SuperAdmin.MenusIndexViewModel
@using School.Domain.Enums
@{
    ViewData["Title"] = "Menus";
    ViewData["ParentViewModel"] = Model;
}

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-list-nested me-2 text-primary"></i>Navigation Menus</h6>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
            <div class="col-sm-4">
                <label class="form-label small">Role</label>
                <select name="role" class="form-select form-select-sm" onchange="this.form.submit()">
                    @foreach (var r in Enum.GetValues<UserRole>())
                    {
                        <option value="@r" selected="@(r == Model.SelectedRole)">@r</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label small">School</label>
                <select name="schoolId" class="form-select form-select-sm" onchange="this.form.submit()"
                        disabled="@(Model.SelectedRole == UserRole.SuperAdmin)">
                    @if (Model.SelectedRole == UserRole.SuperAdmin)
                    {
                        <option>(Global — no school)</option>
                    }
                    else
                    {
                        foreach (var s in Model.Schools)
                        {
                            <option value="@s.Id" selected="@(s.Id == Model.SelectedSchoolId)">@s.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                    <i class="bi bi-plus-circle me-1"></i>Add Menu Item
                </button>
            </div>
        </form>

        @if (!Model.Tree.Any())
        {
            <p class="text-muted text-center py-3 mb-0">No menu items yet for this role/school.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Label</th>
                            <th>Route</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Tree)
                        {
                            <tr>
                                <td><i class="bi @item.IconCssClass me-2"></i>@item.Label</td>
                                <td class="text-muted small">
                                    @(item.Controller is not null ? $"{item.Area}/{item.Controller}/{item.Action}" : "—")
                                </td>
                                <td>
                                    @if (item.IsEnabled)
                                    {
                                        <span class="badge bg-success-subtle text-success">Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Disabled</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @await Html.PartialAsync("_MenuRowActions", item)
                                </td>
                            </tr>
                            @foreach (var child in item.Children)
                            {
                                <tr>
                                    <td class="ps-4"><i class="bi bi-arrow-return-right text-muted me-2"></i><i class="bi @child.IconCssClass me-2"></i>@child.Label</td>
                                    <td class="text-muted small">
                                        @(child.Controller is not null ? $"{child.Area}/{child.Controller}/{child.Action}" : "—")
                                    </td>
                                    <td>
                                        @if (child.IsEnabled)
                                        {
                                            <span class="badge bg-success-subtle text-success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary">Disabled</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @await Html.PartialAsync("_MenuRowActions", child)
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="menuModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="Save" asp-route-schoolId="@Model.SelectedSchoolId" asp-route-role="@Model.SelectedRole" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="menuModalTitle">Add Menu Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="Id" id="Form_Id" value="0" />
                <input type="hidden" name="SchoolId" value="@Model.SelectedSchoolId" />
                <input type="hidden" name="Role" value="@Model.SelectedRole" />
                <div class="mb-3">
                    <label class="form-label">Label</label>
                    <input name="Label" id="Form_Label" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Icon CSS class (Bootstrap Icons, e.g. <code>bi-speedometer2</code>)</label>
                    <input name="IconCssClass" id="Form_IconCssClass" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Parent item</label>
                    <select name="ParentId" id="Form_ParentId" class="form-select">
                        <option value="">— Top level —</option>
                        @foreach (var top in Model.Tree)
                        {
                            <option value="@top.Id">@top.Label</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Section header (top-level items only)</label>
                    <input name="SectionLabel" id="Form_SectionLabel" class="form-control" placeholder="e.g. Main, Academic, Finance" />
                </div>
                <div class="row">
                    <div class="col-4 mb-3">
                        <label class="form-label">Area</label>
                        <input name="Area" id="Form_Area" class="form-control" />
                    </div>
                    <div class="col-4 mb-3">
                        <label class="form-label">Controller</label>
                        <input name="Controller" id="Form_Controller" class="form-control" />
                    </div>
                    <div class="col-4 mb-3">
                        <label class="form-label">Action</label>
                        <input name="Action" id="Form_Action" class="form-control" />
                    </div>
                </div>
                <div class="form-check">
                    <input type="checkbox" name="IsEnabled" id="Form_IsEnabled" class="form-check-input" value="true" checked />
                    <label class="form-check-label" for="Form_IsEnabled">Enabled</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const menuModal = new bootstrap.Modal(document.getElementById('menuModal'));

        function openCreateModal() {
            document.getElementById('menuModalTitle').innerText = 'Add Menu Item';
            document.getElementById('Form_Id').value = '0';
            document.getElementById('Form_Label').value = '';
            document.getElementById('Form_IconCssClass').value = '';
            document.getElementById('Form_ParentId').value = '';
            document.getElementById('Form_SectionLabel').value = '';
            document.getElementById('Form_Area').value = '';
            document.getElementById('Form_Controller').value = '';
            document.getElementById('Form_Action').value = '';
            document.getElementById('Form_IsEnabled').checked = true;
            menuModal.show();
        }

        function openEditModal(data) {
            document.getElementById('menuModalTitle').innerText = 'Edit Menu Item';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_Label').value = data.label;
            document.getElementById('Form_IconCssClass').value = data.icon;
            document.getElementById('Form_ParentId').value = data.parentid || '';
            document.getElementById('Form_SectionLabel').value = data.section || '';
            document.getElementById('Form_Area').value = data.area || '';
            document.getElementById('Form_Controller').value = data.controller || '';
            document.getElementById('Form_Action').value = data.action || '';
            document.getElementById('Form_IsEnabled').checked = data.enabled === 'true';
            menuModal.show();
        }
    </script>
}
