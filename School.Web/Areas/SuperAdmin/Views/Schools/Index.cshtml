@model School.Web.Models.SuperAdmin.SchoolsIndexViewModel
@{ ViewData["Title"] = "Schools"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-building me-2 text-primary"></i>Schools</h6>
        <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
            <i class="bi bi-plus-circle me-1"></i>Add School
        </button>
    </div>
    <div class="card-body">
        @if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-building" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No schools yet</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Items)
                        {
                            <tr>
                                <td>@s.Name</td>
                                <td>
                                    @s.ContactEmail
                                    @if (!string.IsNullOrWhiteSpace(s.ContactPhone))
                                    {
                                        <span class="text-muted">&middot; @s.ContactPhone</span>
                                    }
                                </td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-id="@s.Id" data-name="@s.Name" data-address="@s.Address"
                                            data-email="@s.ContactEmail" data-phone="@s.ContactPhone"
                                            data-isactive="@s.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this.dataset)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-success"
                                            data-id="@s.Id"
                                            onclick="openAdminModal(this.dataset.id)">
                                        <i class="bi bi-person-plus"></i> Create Admin
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="schoolModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="Save" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="schoolModalTitle">Add School</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input asp-for="Form.Name" class="form-control" id="Form_Name" />
                    <span asp-validation-for="Form.Name" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <input asp-for="Form.Address" class="form-control" id="Form_Address" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contact Email</label>
                    <input asp-for="Form.ContactEmail" class="form-control" id="Form_ContactEmail" />
                    <span asp-validation-for="Form.ContactEmail" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Contact Phone</label>
                    <input asp-for="Form.ContactPhone" class="form-control" id="Form_ContactPhone" />
                </div>
                <div class="form-check">
                    <input asp-for="Form.IsActive" class="form-check-input" id="Form_IsActive" />
                    <label class="form-check-label" asp-for="Form.IsActive">Active</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="adminModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="CreateSchoolAdmin" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AdminForm.SchoolId" id="AdminForm_SchoolId" />
            <div class="modal-header">
                <h5 class="modal-title">Create School Admin</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input asp-for="AdminForm.FullName" class="form-control" />
                    <span asp-validation-for="AdminForm.FullName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="AdminForm.Email" class="form-control" />
                    <span asp-validation-for="AdminForm.Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input asp-for="AdminForm.Password" type="text" class="form-control" />
                    <span asp-validation-for="AdminForm.Password" class="text-danger small"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const schoolModal = new bootstrap.Modal(document.getElementById('schoolModal'));
        const adminModal = new bootstrap.Modal(document.getElementById('adminModal'));

        function openCreateModal() {
            document.getElementById('schoolModalTitle').innerText = 'Add School';
            document.getElementById('Form_Id').value = '00000000-0000-0000-0000-000000000000';
            document.getElementById('Form_Name').value = '';
            document.getElementById('Form_Address').value = '';
            document.getElementById('Form_ContactEmail').value = '';
            document.getElementById('Form_ContactPhone').value = '';
            document.getElementById('Form_IsActive').checked = true;
            schoolModal.show();
        }

        function openEditModal(data) {
            document.getElementById('schoolModalTitle').innerText = 'Edit School';
            document.getElementById('Form_Id').value = data.id;
            document.getElementById('Form_Name').value = data.name;
            document.getElementById('Form_Address').value = data.address;
            document.getElementById('Form_ContactEmail').value = data.email;
            document.getElementById('Form_ContactPhone').value = data.phone;
            document.getElementById('Form_IsActive').checked = data.isactive === 'true';
            schoolModal.show();
        }

        function openAdminModal(schoolId) {
            document.getElementById('AdminForm_SchoolId').value = schoolId;
            adminModal.show();
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => schoolModal.show());</text>
        }
        @if (Model.ShowAdminModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => adminModal.show());</text>
        }
    </script>
}
