@model School.Web.Models.Attendance.MarkAttendanceViewModel
@{ ViewData["Title"] = "Mark Attendance"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">Class</label>
                <select name="classId" class="form-select form-select-sm">
                    <option value="">Select a class</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.ClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Division</label>
                <select name="divisionId" class="form-select form-select-sm">
                    <option value="">Select a division</option>
                    @foreach (var d in Model.Divisions)
                    {
                        <option value="@d.Id" selected="@(Model.DivisionId == d.Id)">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Date</label>
                <input type="date" name="date" value="@Model.Date?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Load Roster</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar-check me-2 text-primary"></i>Roster</h6>
    </div>
    <div class="card-body">
        @if (!Model.ClassId.HasValue || !Model.DivisionId.HasValue)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-funnel" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Select a Class, Division, and Date to load the roster.</p>
            </div>
        }
        else if (!Model.Rows.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-people" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No students found in this class/division.</p>
            </div>
        }
        else
        {
            <form asp-action="Save" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ClassId" />
                <input type="hidden" asp-for="DivisionId" />
                <input type="hidden" asp-for="Date" />

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>GR No.</th>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Half Day</th>
                                <th>Late</th>
                                <th>Remark</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>
                                    <td>@Model.Rows[i].GRNumber</td>
                                    <td>
                                        @Model.Rows[i].StudentName
                                        <input type="hidden" asp-for="Rows[i].StudentId" />
                                        <input type="hidden" asp-for="Rows[i].StudentName" />
                                        <input type="hidden" asp-for="Rows[i].GRNumber" />
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <input type="radio" class="btn-check" name="Rows[@i].IsPresent" id="present_@i" value="true" checked="@Model.Rows[i].IsPresent" />
                                            <label class="btn btn-outline-success" for="present_@i">Present</label>
                                            <input type="radio" class="btn-check" name="Rows[@i].IsPresent" id="absent_@i" value="false" checked="@(!Model.Rows[i].IsPresent)" />
                                            <label class="btn btn-outline-danger" for="absent_@i">Absent</label>
                                        </div>
                                    </td>
                                    <td><input type="checkbox" asp-for="Rows[i].IsHalfDay" class="form-check-input" /></td>
                                    <td><input type="checkbox" asp-for="Rows[i].IsLate" class="form-check-input" /></td>
                                    <td><input asp-for="Rows[i].Remark" class="form-control form-control-sm" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i>Save Attendance</button>
            </form>
        }
    </div>
</div>
