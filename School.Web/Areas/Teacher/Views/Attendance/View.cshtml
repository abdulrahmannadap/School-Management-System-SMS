@model School.Web.Models.Attendance.ViewAttendanceViewModel
@{ ViewData["Title"] = "Attendance Records"; }

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small">Name</label>
                <input type="text" name="name" value="@Model.Search.Name" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-4">
                <label class="form-label small">GR Number</label>
                <input type="text" name="grNumber" value="@Model.Search.GRNumber" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-4">
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search me-1"></i>Search</button>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedStudent is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-people me-2 text-primary"></i>Search Results</h6>
        </div>
        <div class="card-body">
            @if (string.IsNullOrWhiteSpace(Model.Search.Name) && string.IsNullOrWhiteSpace(Model.Search.GRNumber))
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-search" style="font-size:2.5rem;opacity:.3"></i>
                    <p class="mt-2 mb-0">Search by Name or GR Number to view a student's attendance.</p>
                </div>
            }
            else if (!Model.SearchResults.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-person-x" style="font-size:2.5rem;opacity:.3"></i>
                    <p class="mt-2 mb-0">No students found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr><th>GR No.</th><th>Name</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.SearchResults)
                            {
                                <tr>
                                    <td>@s.GRNumber</td>
                                    <td>@s.FullName</td>
                                    <td class="text-end">
                                        <a asp-action="View" asp-route-studentId="@s.Id" class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-semibold mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>@Model.SelectedStudent.FullName</h6>
                <div class="text-muted small">GR No. @Model.SelectedStudent.GRNumber &middot; @Model.From.ToString("dd MMM yyyy") &ndash; @Model.To.ToString("dd MMM yyyy")</div>
            </div>
            <a asp-action="View" class="btn btn-outline-secondary btn-sm">Back to Search</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var stat in new[] {
            ("bi-calendar3",      "bg-primary", "Total Days",  Model.Summary?.TotalDays.ToString() ?? "0"),
            ("bi-check-circle",   "bg-success", "Present",     Model.Summary?.PresentDays.ToString() ?? "0"),
            ("bi-x-circle",       "bg-danger",  "Absent",      Model.Summary?.AbsentDays.ToString() ?? "0"),
            ("bi-clock-history",  "bg-warning", "Late",        Model.Summary?.LateCount.ToString() ?? "0"),
        })
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 @stat.Item2 bg-opacity-10">
                            <i class="bi @stat.Item1 @stat.Item2.Replace("bg-","text-") fs-3"></i>
                        </div>
                        <div>
                            <div class="text-muted small">@stat.Item3</div>
                            <div class="fw-bold fs-4">@stat.Item4</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-journal-text me-2 text-primary"></i>Day-by-Day</h6>
        </div>
        <div class="card-body">
            @if (!Model.Entries.Any())
            {
                <p class="text-muted text-center py-3 mb-0">No attendance recorded in this range</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr><th>Date</th><th>Status</th><th>Half Day</th><th>Late</th><th>Remark</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.Entries.OrderByDescending(e => e.Date))
                            {
                                <tr>
                                    <td>@entry.Date.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (entry.IsPresent)
                                        {
                                            <span class="badge bg-success-subtle text-success">Present</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger">Absent</span>
                                        }
                                    </td>
                                    <td>@(entry.IsHalfDay ? "Yes" : "—")</td>
                                    <td>@(entry.IsLate ? "Yes" : "—")</td>
                                    <td>@entry.Remark</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
