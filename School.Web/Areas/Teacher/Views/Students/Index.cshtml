@model School.Web.Models.Students.StudentsIndexViewModel
@{ ViewData["Title"] = "Admission"; }

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">Name</label>
                <input type="text" name="Name" value="@Model.Search.Name" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-3">
                <label class="form-label small">GR Number</label>
                <input type="text" name="GRNumber" value="@Model.Search.GRNumber" class="form-control form-control-sm" />
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Class</label>
                <select name="ClassId" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id" selected="@(Model.Search.ClassId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Division</label>
                <select name="DivisionId" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var d in Model.Divisions)
                    {
                        <option value="@d.Id" selected="@(Model.Search.DivisionId == d.Id)">@d.Name</option>
                    }
                </select>
            </div>
            <div class="col-sm-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-person-plus-fill me-2 text-primary"></i>Admission</h6>
        @if (Model.Classes.Any() && Model.Divisions.Any() && Model.FinancialYears.Any())
        {
            <button type="button" class="btn btn-sm btn-primary" onclick="openCreateModal()">
                <i class="bi bi-person-plus me-1"></i>Add New
            </button>
        }
    </div>
    <div class="card-body">
        @if (!Model.Classes.Any() || !Model.Divisions.Any() || !Model.FinancialYears.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-exclamation-triangle" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">Set up Financial Year, Class and Division under Masters first.</p>
            </div>
        }
        else if (!Model.Items.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-people" style="font-size:2.5rem;opacity:.3"></i>
                <p class="mt-2 mb-0">No students found</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>GR No.</th>
                            <th>Name</th>
                            <th>Class / Division</th>
                            <th>Gender</th>
                            <th>DOB</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.GRNumber</td>
                                <td>@item.FullName</td>
                                <td>
                                    @(Model.Classes.FirstOrDefault(c => c.Id == item.ClassId)?.Name ?? "—")
                                    / @(Model.Divisions.FirstOrDefault(d => d.Id == item.DivisionId)?.Name ?? "—")
                                </td>
                                <td>@item.Gender</td>
                                <td>@item.DateOfBirth.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            onclick="openEditModal(@item.Id)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    @if (item.IsActive)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Deactivate this student? Their record is kept but marked inactive.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deactivate"><i class="bi bi-person-dash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="studentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <form asp-action="Save" method="post" class="modal-content" id="studentForm">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="studentModalTitle">Add Student — Admission</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" asp-for="Form.Id" id="Form_Id" />

                <div class="row" id="fyField">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Financial Year</label>
                        <select asp-for="Form.FinancialYearId" class="form-select" id="Form_FinancialYearId">
                            <option value="">Select financial year</option>
                            @foreach (var fy in Model.FinancialYears)
                            {
                                <option value="@fy.Id">@fy.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.FinancialYearId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Full Name<span class="text-danger">*</span></label>
                        <input asp-for="Form.FullName" class="form-control" id="Form_FullName" />
                        <span asp-validation-for="Form.FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Gender<span class="text-danger">*</span></label>
                        <select asp-for="Form.Gender" class="form-select" id="Form_Gender">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Form.Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Date of Birth<span class="text-danger">*</span></label>
                        <input asp-for="Form.DateOfBirth" type="date" class="form-control" id="Form_DateOfBirth" />
                        <span asp-validation-for="Form.DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Class <span class="text-muted small fw-normal">(optional at admission)</span></label>
                        <select asp-for="Form.ClassId" class="form-select" id="Form_ClassId">
                            <option value="">Not decided yet</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.ClassId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Division <span class="text-muted small fw-normal">(optional at admission)</span></label>
                        <select asp-for="Form.DivisionId" class="form-select" id="Form_DivisionId">
                            <option value="">Not decided yet</option>
                            @foreach (var d in Model.Divisions)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.DivisionId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3" id="emailField">
                        <label class="form-label">Email</label>
                        <input asp-for="Form.Email" class="form-control" id="Form_Email" />
                        <span asp-validation-for="Form.Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3 form-check pt-4" id="isActiveField">
                        <input asp-for="Form.IsActive" class="form-check-input" id="Form_IsActive" />
                        <label class="form-check-label" asp-for="Form.IsActive">Active</label>
                    </div>
                </div>

                <div id="admissionExtra">
                    <hr />
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-personal" type="button">More Personal Details</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-parent" type="button">Parent / Guardian</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-address" type="button">Address</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-contact" type="button">Contact</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-admission" type="button">Admission Details</button></li>
                    </ul>
                    <div class="tab-content border border-top-0 p-3 rounded-bottom">
                        <div class="tab-pane fade show active" id="tab-personal">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">First Name</label>
                                    <input asp-for="Form.FirstName" class="form-control" id="Form_FirstName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Middle Name</label>
                                    <input asp-for="Form.MiddleName" class="form-control" id="Form_MiddleName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input asp-for="Form.LastName" class="form-control" id="Form_LastName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Place of Birth</label>
                                    <input asp-for="Form.PlaceOfBirth" class="form-control" id="Form_PlaceOfBirth" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mother Tongue</label>
                                    <input asp-for="Form.MotherTongue" class="form-control" id="Form_MotherTongue" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Religion</label>
                                    <input asp-for="Form.Religion" class="form-control" id="Form_Religion" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Blood Group</label>
                                    <input asp-for="Form.BloodGroup" class="form-control" id="Form_BloodGroup" placeholder="e.g. O+" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Nationality</label>
                                    <input asp-for="Form.Nationality" class="form-control" id="Form_Nationality" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Native Place</label>
                                    <input asp-for="Form.NativePlace" class="form-control" id="Form_NativePlace" />
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-parent">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Name</label>
                                    <input asp-for="Form.FatherName" class="form-control" id="Form_FatherName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Qualification</label>
                                    <input asp-for="Form.FatherQualification" class="form-control" id="Form_FatherQualification" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Occupation</label>
                                    <input asp-for="Form.FatherOccupation" class="form-control" id="Form_FatherOccupation" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Income</label>
                                    <input asp-for="Form.FatherIncome" type="number" step="0.01" class="form-control" id="Form_FatherIncome" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Mobile</label>
                                    <input asp-for="Form.FatherMobile" class="form-control" id="Form_FatherMobile" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mother's Name</label>
                                    <input asp-for="Form.MotherName" class="form-control" id="Form_MotherName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mother's Qualification</label>
                                    <input asp-for="Form.MotherQualification" class="form-control" id="Form_MotherQualification" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mother's Mobile</label>
                                    <input asp-for="Form.MotherMobile" class="form-control" id="Form_MotherMobile" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Guardian's Name</label>
                                    <input asp-for="Form.GuardianName" class="form-control" id="Form_GuardianName" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Guardian's Relation</label>
                                    <input asp-for="Form.GuardianRelation" class="form-control" id="Form_GuardianRelation" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Guardian's Mobile</label>
                                    <input asp-for="Form.GuardianMobile" class="form-control" id="Form_GuardianMobile" />
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-address">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Flat / House No.</label>
                                    <input asp-for="Form.FlatNo" class="form-control" id="Form_FlatNo" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Building</label>
                                    <input asp-for="Form.Building" class="form-control" id="Form_Building" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Area</label>
                                    <input asp-for="Form.Area" class="form-control" id="Form_Area" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Landmark</label>
                                    <input asp-for="Form.Landmark" class="form-control" id="Form_Landmark" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">City</label>
                                    <input asp-for="Form.City" class="form-control" id="Form_City" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">District</label>
                                    <input asp-for="Form.District" class="form-control" id="Form_District" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">State</label>
                                    <input asp-for="Form.State" class="form-control" id="Form_State" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Pin Code</label>
                                    <input asp-for="Form.PinCode" class="form-control" id="Form_PinCode" />
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-contact">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Father's Phone</label>
                                    <input asp-for="Form.FatherPhone" class="form-control" id="Form_FatherPhone" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mother's Phone</label>
                                    <input asp-for="Form.MotherPhone" class="form-control" id="Form_MotherPhone" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Guardian's Phone</label>
                                    <input asp-for="Form.GuardianPhone" class="form-control" id="Form_GuardianPhone" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">WhatsApp No.</label>
                                    <input asp-for="Form.WhatsAppNo" class="form-control" id="Form_WhatsAppNo" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Contact Email</label>
                                    <input asp-for="Form.ContactEmail" class="form-control" id="Form_ContactEmail" />
                                    <span asp-validation-for="Form.ContactEmail" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tab-admission">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Last School Attended</label>
                                    <input asp-for="Form.LastSchoolAttended" class="form-control" id="Form_LastSchoolAttended" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Previous Class</label>
                                    <input asp-for="Form.PreviousClass" class="form-control" id="Form_PreviousClass" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Medium</label>
                                    <input asp-for="Form.Medium" class="form-control" id="Form_Medium" placeholder="e.g. English" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Admission Date</label>
                                    <input asp-for="Form.AdmissionDate" type="date" class="form-control" id="Form_AdmissionDate" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Academic Year</label>
                                    <select asp-for="Form.AcademicYearId" class="form-select" id="Form_AcademicYearId">
                                        <option value="">Select academic year</option>
                                        @foreach (var ay in Model.AcademicYears)
                                        {
                                            <option value="@ay.Id">@ay.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Receipt No.</label>
                                    <input asp-for="Form.ReceiptNo" class="form-control" id="Form_ReceiptNo" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Form No.</label>
                                    <input asp-for="Form.FormNo" class="form-control" id="Form_FormNo" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Admission Confirmed Class</label>
                                    <input asp-for="Form.AdmissionConfirmedClass" class="form-control" id="Form_AdmissionConfirmedClass" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Clerk Name</label>
                                    <input asp-for="Form.ClerkName" class="form-control" id="Form_ClerkName" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const studentModal = new bootstrap.Modal(document.getElementById('studentModal'));
        const studentForm = document.getElementById('studentForm');
        const detailsUrlTemplate = '@Url.Action("Details", new { id = "__ID__" })';

        // Financial Year only applies at first admission; Active toggle only makes sense
        // once a record exists. Every other section (personal/parent/address/contact/
        // admission) is editable both when creating and when editing.
        function toggleCreateOnlyFields(isCreate) {
            document.getElementById('fyField').style.display = isCreate ? '' : 'none';
            document.getElementById('isActiveField').style.display = isCreate ? 'none' : '';
        }

        function resetToFirstTab() {
            const firstTabBtn = document.querySelector('#admissionExtra .nav-link');
            if (firstTabBtn) bootstrap.Tab.getOrCreateInstance(firstTabBtn).show();
        }

        function setVal(id, value) {
            const el = document.getElementById(id);
            if (el) el.value = value ?? '';
        }

        function openCreateModal() {
            document.getElementById('studentModalTitle').innerText = 'Add Student — Admission';
            studentForm.reset();
            document.getElementById('Form_Id').value = 0;
            toggleCreateOnlyFields(true);
            resetToFirstTab();
            studentModal.show();
        }

        async function openEditModal(id) {
            document.getElementById('studentModalTitle').innerText = 'Edit Student';
            studentForm.reset();
            resetToFirstTab();
            toggleCreateOnlyFields(false);
            studentModal.show();

            const res = await fetch(detailsUrlTemplate.replace('__ID__', id));
            if (!res.ok) return;
            const data = await res.json();
            const s = data.student ?? {};
            const p = data.parent ?? {};
            const a = data.address ?? {};
            const c = data.contact ?? {};
            const ad = data.admission ?? {};

            setVal('Form_Id', id);
            setVal('Form_ClassId', s.classId);
            setVal('Form_DivisionId', s.divisionId);
            setVal('Form_FullName', s.fullName);
            setVal('Form_FirstName', s.firstName);
            setVal('Form_MiddleName', s.middleName);
            setVal('Form_LastName', s.lastName);
            setVal('Form_Gender', s.gender);
            setVal('Form_DateOfBirth', (s.dateOfBirth || '').substring(0, 10));
            setVal('Form_PlaceOfBirth', s.placeOfBirth);
            setVal('Form_MotherTongue', s.motherTongue);
            setVal('Form_Religion', s.religion);
            setVal('Form_BloodGroup', s.bloodGroup);
            setVal('Form_Nationality', s.nationality);
            setVal('Form_NativePlace', s.nativePlace);
            setVal('Form_Email', s.email);
            document.getElementById('Form_IsActive').checked = !!s.isActive;

            setVal('Form_FatherName', p.fatherName);
            setVal('Form_FatherQualification', p.fatherQualification);
            setVal('Form_FatherOccupation', p.fatherOccupation);
            setVal('Form_FatherIncome', p.fatherIncome);
            setVal('Form_FatherMobile', p.fatherMobile);
            setVal('Form_MotherName', p.motherName);
            setVal('Form_MotherQualification', p.motherQualification);
            setVal('Form_MotherMobile', p.motherMobile);
            setVal('Form_GuardianName', p.guardianName);
            setVal('Form_GuardianRelation', p.guardianRelation);
            setVal('Form_GuardianMobile', p.guardianMobile);

            setVal('Form_FlatNo', a.flatNo);
            setVal('Form_Building', a.building);
            setVal('Form_Area', a.area);
            setVal('Form_City', a.city);
            setVal('Form_Landmark', a.landmark);
            setVal('Form_District', a.district);
            setVal('Form_State', a.state);
            setVal('Form_PinCode', a.pinCode);

            setVal('Form_FatherPhone', c.fatherPhone);
            setVal('Form_MotherPhone', c.motherPhone);
            setVal('Form_GuardianPhone', c.guardianPhone);
            setVal('Form_WhatsAppNo', c.whatsAppNo);
            setVal('Form_ContactEmail', c.email);

            setVal('Form_LastSchoolAttended', ad.lastSchoolAttended);
            setVal('Form_PreviousClass', ad.previousClass);
            setVal('Form_Medium', ad.medium);
            setVal('Form_AdmissionDate', (ad.admissionDate || '').substring(0, 10));
            setVal('Form_ReceiptNo', ad.receiptNo);
            setVal('Form_FormNo', ad.formNo);
            setVal('Form_AcademicYearId', ad.academicYearId || '');
            setVal('Form_AdmissionConfirmedClass', ad.admissionConfirmedClass);
            setVal('Form_ClerkName', ad.clerkName);
        }

        @if (Model.ShowModal)
        {
            <text>window.addEventListener('DOMContentLoaded', () => { toggleCreateOnlyFields(@(Model.Form.Id == 0 ? "true" : "false")); studentModal.show(); });</text>
        }
    </script>
}
