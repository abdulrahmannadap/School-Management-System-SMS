@using Microsoft.Extensions.Caching.Memory
@inject School.Application.Interfaces.ICurrentSchoolContext CurrentSchool
@inject School.Application.Interfaces.ISchoolService SchoolSvc
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache SchoolNameCache
@{
    string effectiveSchoolName;
    if (CurrentSchool.SchoolId is { } schoolId)
    {
        effectiveSchoolName = await SchoolNameCache.GetOrCreateAsync($"school-name:{schoolId}", async entry =>
        {
            entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(5);
            return (await SchoolSvc.GetAsync(schoolId))?.Name ?? "Unknown School";
        }) ?? "Unknown School";
    }
    else
    {
        effectiveSchoolName = "SMS Platform";
    }
    ViewData["EffectiveSchoolName"] = effectiveSchoolName;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Blocking, non-deferred: sets the persisted theme before any CSS paints. -->
    <script src="~/js/theme-init.js" asp-append-version="true"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – @effectiveSchoolName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar Overlay (mobile) -->
<div id="sidebarOverlay" class="sidebar-overlay"></div>

@await RenderSectionAsync("Sidebar", required: true)

<!-- ═══════════════════════ MAIN WRAPPER ═══════════════════════ -->
<div class="main-wrapper">
    <partial name="_Header" />
    <partial name="_Breadcrumb" />

    <!-- Page Body -->
    <div class="page-body">
        @RenderBody()
    </div>

    <partial name="_Footer" />
</div>

<partial name="_Loader" />
<partial name="_Scripts" />
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
