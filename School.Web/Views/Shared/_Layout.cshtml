<!-- ═══════════════════════ MAIN WRAPPER ═══════════════════════ -->
<div class="main-wrapper">

    <!-- Topbar -->
    <header class="topbar">
        <button type="button" id="sidebarMobileToggle" class="btn-toggle" aria-label="Toggle menu" title="Toggle Menu">
            <i class="bi bi-list"></i>
        </button>
        <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>

        @if (CurrentSchool.IsImpersonating)
        {
            <form asp-controller="Impersonation" asp-action="Stop" asp-area="" method="post" class="d-inline ms-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-warning">
                    <i class="bi bi-eye-slash me-1"></i>Exit impersonation (@effectiveSchoolName)
                </button>
            </form>
        }

        <!-- Notifications -->
        <div class="dropdown">
            <button class="notif-btn" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                <i class="bi bi-bell"></i>
                @{ int notifCount = ViewBag.NotificationCount ?? 0; }
                @if (notifCount > 0)
                {
                    <span class="notif-badge">@notifCount</span>
                }
            </button>
            <div class="dropdown-menu dropdown-menu-end notif-dropdown">
                <div class="notif-header">
                    <i class="bi bi-bell me-1"></i> Notifications
                    @if (notifCount > 0){ <span class="badge bg-danger ms-1">@notifCount</span> }
                </div>
                @if (notifCount == 0)
                {
                    <div class="notif-empty">
                        <i class="bi bi-bell-slash d-block mb-1 notif-empty-icon"></i>
                        No new notifications
                    </div>
                }
                else
                {
                    @await Html.PartialAsync("_Notifications")
                }
            </div>
        </div>

        <!-- User Dropdown -->
        <div class="dropdown">
            <button class="user-btn d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                @{ var initials = string.Concat((User.Identity?.Name ?? "U").Split(' ').Select(w => w.FirstOrDefault()).Take(2)); }
                <div class="user-avatar">@initials</div>
                <span class="d-none d-md-inline user-info">
                    @User.Identity?.Name
                    <small class="text-muted d-block user-role-label">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                </span>
                <i class="bi bi-chevron-down user-chevron"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                <li><h6 class="dropdown-header">@User.Identity?.Name</h6></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </header>

    <!-- Page Body -->
    <div class="page-body">
        @RenderBody()
    </div>

    <footer class="text-center text-muted py-3 app-footer">
        &copy; @DateTime.Now.Year @effectiveSchoolName &mdash; School Management System
    </footer>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/sidebar.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
