<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Wisdom Academy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --sidebar-w: 260px; --sidebar-bg: #1e293b; --sidebar-hover: #334155; --accent: #3b82f6; }
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }

        /* ── Sidebar ── */
        .sidebar { width: var(--sidebar-w); min-height: 100vh; background: var(--sidebar-bg);
                   position: fixed; top: 0; left: 0; z-index: 1050;
                   display: flex; flex-direction: column; transition: transform .25s ease; }

        .sidebar-brand { padding: 1.1rem 1.4rem; border-bottom: 1px solid #334155;
                         color: #fff; text-decoration: none;
                         display: flex; align-items: center; gap: .7rem; }
        .sidebar-brand i { font-size: 1.6rem; color: var(--accent); flex-shrink: 0; }
        .brand-name { font-size: .98rem; font-weight: 700; letter-spacing: .03em; line-height: 1.2; }
        .brand-sub  { font-size: .65rem; color: #64748b; letter-spacing: .05em; text-transform: uppercase; }

        .sidebar-nav { padding: .5rem 0 1rem; flex: 1; overflow-y: auto; }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }

        .nav-section { color: #475569; font-size: .63rem; font-weight: 700; letter-spacing: .1em;
                       text-transform: uppercase; padding: .9rem 1.4rem .25rem; }

        /* top-level nav link */
        .sidebar-nav .nav-link {
            color: #94a3b8; padding: .5rem 1.4rem;
            display: flex; align-items: center; gap: .7rem;
            border-radius: 0; font-size: .855rem; transition: all .15s;
            text-decoration: none; cursor: pointer;
        }
        .sidebar-nav .nav-link:hover  { color: #fff; background: var(--sidebar-hover); }
        .sidebar-nav .nav-link.active { color: #fff; background: var(--accent); }
        .sidebar-nav .nav-link i.nav-icon { font-size: 1rem; width: 1.1rem; text-align: center; flex-shrink: 0; }

        /* chevron for collapsible parents */
        .nav-link .chevron { margin-left: auto; font-size: .75rem; color: #64748b;
                             transition: transform .2s ease; flex-shrink: 0; }
        .nav-link[aria-expanded="true"] .chevron { transform: rotate(180deg); }
        .nav-link[aria-expanded="true"] { color: #e2e8f0; }

        /* sub-menu */
        .sub-nav { padding: 0; list-style: none; margin: 0;
                   background: rgba(0,0,0,.18); }
        .sub-nav .nav-link { padding: .42rem 1.4rem .42rem 3.1rem; font-size: .82rem; }
        .sub-nav .nav-link i.nav-icon { font-size: .85rem; }

        /* ── Main ── */
        .main-wrapper { margin-left: var(--sidebar-w); min-height: 100vh;
                        display: flex; flex-direction: column; }
        .topbar { background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.08);
                  padding: .6rem 1.5rem; display: flex; align-items: center;
                  gap: .75rem; position: sticky; top: 0; z-index: 1040; }
        .topbar .btn-toggle { background: none; border: none; font-size: 1.3rem;
                              color: #64748b; cursor: pointer; padding: 0 .4rem; display: none; }
        .topbar .page-title  { font-weight: 600; font-size: 1rem; color: #1e293b; flex: 1; }
        .notif-btn, .user-btn { background: none; border: none; position: relative;
                                 color: #64748b; font-size: 1.1rem; padding: .3rem .5rem;
                                 border-radius: .4rem; transition: background .15s; }
        .notif-btn:hover, .user-btn:hover { background: #f1f5f9; }
        .notif-badge { position: absolute; top: 1px; right: 1px; background: #ef4444;
                       color: #fff; font-size: .6rem; width: 16px; height: 16px;
                       border-radius: 50%; display: flex; align-items: center;
                       justify-content: center; font-weight: 700; }
        .user-info { display: flex; align-items: center; gap: .45rem;
                     font-size: .85rem; color: #1e293b; font-weight: 500; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%;
                       background: var(--accent); color: #fff;
                       display: flex; align-items: center; justify-content: center;
                       font-weight: 700; font-size: .8rem; flex-shrink: 0; }
        .page-body { padding: 1.5rem; flex: 1; }

        /* ── Notification dropdown ── */
        .notif-dropdown { min-width: 320px; padding: 0; border: none;
                          box-shadow: 0 8px 30px rgba(0,0,0,.12); border-radius: .6rem; }
        .notif-header { padding: .75rem 1rem; border-bottom: 1px solid #e2e8f0;
                        font-weight: 600; font-size: .9rem; color: #1e293b; }
        .notif-item { padding: .7rem 1rem; border-bottom: 1px solid #f1f5f9;
                      font-size: .83rem; color: #475569; display: flex; gap: .6rem; align-items: flex-start; }
        .notif-item i { margin-top: 2px; color: var(--accent); }
        .notif-empty  { padding: 1.5rem; text-align: center; color: #94a3b8; font-size: .85rem; }

        /* ── Mobile ── */
        .sidebar-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45);
                           z-index: 1045; display: none; }
        @@media (max-width: 991px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-wrapper { margin-left: 0; }
            .topbar .btn-toggle { display: block; }
        }
        .brand-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 50%;
    background: #fff;
    padding: 3px;
}


    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
