@* Render notification items - populated via ViewBag.Notifications *@
@if (ViewBag.Notifications is IEnumerable<string> items)
{
    foreach (var item in items)
    {
        <div class="notif-item">
            <i class="bi bi-info-circle-fill"></i>
            <span>@item</span>
        </div>
    }
}
